<%- include('partials/header', { activePage: 'logs' }) %>

<div class="max-w-[1400px] mx-auto pb-20">
  <!-- Header Section -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-8 px-2">
    <div>
      <h1 class="text-5xl font-black text-white tracking-tighter flex items-center gap-5">
        <span class="w-2.5 h-12 bg-gradient-to-b from-primary-400 to-primary-700 rounded-full shadow-[0_0_20px_rgba(var(--primary-rgb),0.4)] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 text-white/50">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
        </span>
        Audit Trail
      </h1>
      <p class="text-slate-500 mt-3 font-medium text-lg italic opacity-80 leading-relaxed">Rekaman aktivitas sistem, akses administrator, dan automasi bel harian.</p>
    </div>

    <!-- Quick Stats -->
    <div class="flex gap-4">
        <div class="glass-premium px-6 py-4 rounded-3xl border border-white/5 flex flex-col justify-center">
            <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest leading-none mb-2">Logged Entries</span>
            <span class="text-white font-black text-xl"><%= totalEntries %></span>
        </div>
        <div class="glass-premium px-6 py-4 rounded-3xl border border-white/5 flex flex-col justify-center">
            <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest leading-none mb-2">Total Pages</span>
            <span class="text-white font-black text-xl"><%= totalPages %></span>
        </div>
    </div>
  </div>

  <!-- Logs Table Container -->
  <div class="glass-premium rounded-[4rem] border border-white/5 relative group overflow-hidden mb-12">
    <div class="absolute -right-32 -bottom-32 w-96 h-96 bg-primary-600 rounded-full opacity-[0.03] blur-[120px] group-hover:opacity-[0.08] transition-opacity duration-1000"></div>
    
    <div class="p-10 lg:p-14 relative z-10">
      <div class="overflow-x-auto custom-scrollbar">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-white/5">
              <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.4em] text-slate-500 pb-8">Timestamp</th>
              <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.4em] text-slate-500 pb-8">Category</th>
              <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.4em] text-slate-500 pb-8">Activity Description</th>
              <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.4em] text-slate-500 pb-8 text-right">Executor</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% logs.forEach(log => { %>
              <tr class="group hover:bg-white/[0.02] transition-all duration-300">
                <td class="px-8 py-8 whitespace-nowrap">
                   <div class="flex flex-col">
                      <span class="text-sm font-black text-white"><%= new Date(log.timestamp).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' }).replace(/\./g, ':') %></span>
                      <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest mt-1.5"><%= new Date(log.timestamp).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                   </div>
                </td>
                <td class="px-8 py-8 whitespace-nowrap">
                    <% 
                      let typeColor = 'bg-slate-500/10 text-slate-400 border-slate-500/20';
                      if (log.type === 'auth') typeColor = 'bg-primary-500/10 text-primary-400 border-primary-500/20';
                      if (log.type === 'audio') typeColor = 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
                      if (log.type === 'config') typeColor = 'bg-orange-500/10 text-orange-400 border-orange-500/20';
                    %>
                    <div class="inline-flex items-center gap-2 px-4 py-2 <%= typeColor %> border rounded-xl">
                        <span class="text-[9px] font-black uppercase tracking-[0.2em] italic"><%= log.type || 'System' %></span>
                    </div>
                </td>
                <td class="px-8 py-8">
                    <p class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors leading-relaxed italic"><%= log.message %></p>
                </td>
                <td class="px-8 py-8 text-right whitespace-nowrap">
                    <div class="inline-flex items-center gap-3">
                        <span class="text-[10px] font-black text-white/50 uppercase tracking-widest"><%= log.user || 'System' %></span>
                        <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/5 flex items-center justify-center font-black text-[10px] text-slate-500">
                             <%= (log.user || 'S').charAt(0).toUpperCase() %>
                        </div>
                    </div>
                </td>
              </tr>
            <% }) %>
            <% if (logs.length === 0) { %>
              <tr>
                <td colspan="4" class="px-8 py-32 text-center opacity-20 italic">
                  <p class="text-sm font-black uppercase tracking-[0.5em]">No activity logs found</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Modern Pagination Controls -->
  <div class="flex flex-col md:flex-row items-center justify-between gap-8 px-8">
     <div class="text-[10px] font-black text-slate-600 uppercase tracking-[0.3em] italic">
        Viewing entries <%= (currentPage - 1) * 20 + 1 %> - <%= Math.min(currentPage * 20, totalEntries) %> of <%= totalEntries %>
     </div>

     <div class="flex items-center gap-2">
        <% if (currentPage > 1) { %>
          <a href="/logs?page=<%= currentPage - 1 %>" class="px-5 py-3 glass-premium text-white border border-white/10 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-white/10 transition-all flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
            Previous
          </a>
        <% } else { %>
          <span class="px-5 py-3 glass-premium text-slate-600 border border-white/5 rounded-xl font-black text-[10px] uppercase tracking-widest opacity-30 cursor-not-allowed flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
            Previous
          </span>
        <% } %>

        <div class="flex items-center gap-1.5 px-4">
            <% 
              let start = Math.max(1, currentPage - 2);
              let end = Math.min(totalPages, start + 4);
              if (end - start < 4) start = Math.max(1, end - 4);
              for (let i = start; i <= end; i++) { 
            %>
              <a href="/logs?page=<%= i %>" class="w-10 h-10 flex items-center justify-center rounded-xl text-[10px] font-black transition-all <%= i === currentPage ? 'bg-primary-600 text-white shadow-lg' : 'text-slate-500 hover:text-white hover:bg-white/5' %>"><%= i %></a>
            <% } %>
        </div>

        <% if (currentPage < totalPages) { %>
          <a href="/logs?page=<%= currentPage + 1 %>" class="px-5 py-3 glass-premium text-white border border-white/10 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-white/10 transition-all flex items-center gap-2">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </a>
        <% } else { %>
          <span class="px-5 py-3 glass-premium text-slate-600 border border-white/5 rounded-xl font-black text-[10px] uppercase tracking-widest opacity-30 cursor-not-allowed flex items-center gap-2">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </span>
        <% } %>
     </div>
  </div>
  
</div>

<%- include('partials/footer') %>
