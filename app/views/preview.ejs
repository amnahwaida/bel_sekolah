<%- include('partials/header') %>

<div class="max-w-2xl mx-auto mt-12">
  <div class="bg-white dark:bg-slate-900 p-10 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none transition-all">
    <div class="flex items-center gap-4 mb-8">
      <div class="bg-emerald-50 dark:bg-emerald-900/30 w-14 h-14 rounded-2xl flex items-center justify-center shadow-inner transition-colors">
        <!-- SpeakerWaveIcon (Outline) -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-emerald-600 dark:text-emerald-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.287a6 6 0 010 7.427M12 6.75l6.75 6.75-6.75 6.75V6.75z" />
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-black text-slate-800 dark:text-slate-100 tracking-tight transition-colors">Pratinjau Audio</h1>
        <p class="text-slate-400 dark:text-slate-500 font-medium text-sm transition-colors">Mendengarkan berkas sebelum dijadwalkan</p>
      </div>
    </div>
    
    <div class="bg-slate-50 dark:bg-slate-800 p-8 rounded-[2rem] border border-slate-100 dark:border-slate-700 mb-10 transition-all">
      <div class="mb-4 flex items-center justify-between">
        <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500 transition-colors">Nama Berkas</span>
        <span class="text-[10px] font-black uppercase tracking-widest text-emerald-500 bg-emerald-50 dark:bg-emerald-900/40 px-2 py-0.5 rounded-full transition-colors flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
             <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
          </svg>
          Active
        </span>
      </div>
      <div class="text-lg font-bold text-slate-700 dark:text-slate-200 mb-6 truncate transition-colors"><%= file %></div>
      
      <audio controls class="w-full custom-audio-player transition-all">
        <source src="/music/<%= file %>" type="audio/mpeg">
        Your browser does not support the audio element.
      </audio>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/dashboard" class="flex-1 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-400 px-6 py-4 rounded-2xl font-bold transition-all text-center flex items-center justify-center gap-2">
        <!-- ArrowLeftIcon (Outline) -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Kembali
      </a>
      <form method="POST" action="/play" class="flex-[2]" onsubmit="return handlePreviewPlay(this)">
        <input type="hidden" name="file" value="<%= file %>" />
        <button type="submit" id="btnPreviewPlay" class="w-full bg-emerald-600 border-b-4 border-emerald-700 hover:bg-emerald-500 hover:border-emerald-600 text-white px-6 py-4 rounded-2xl font-black text-sm uppercase tracking-widest shadow-lg shadow-emerald-500/20 dark:shadow-none transition-all active:scale-[0.98] active:border-b-0 flex items-center justify-center gap-2">
          <!-- PlayIcon (Solid) -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
          </svg>
          <span id="previewPlayText">Putar di Speaker Sekolah</span>
        </button>
      </form>
    </div>

<script>
  function handlePreviewPlay(form) {
    const btn = form.querySelector('#btnPreviewPlay');
    const text = form.querySelector('#previewPlayText');
    if (btn.disabled) return false;
    btn.disabled = true;
    btn.classList.add('opacity-50');
    btn.style.pointerEvents = 'none';
    if (text) text.innerText = '⏳ MEMPROSES...';
    setTimeout(() => {
      btn.disabled = false;
      btn.classList.remove('opacity-50');
      btn.style.pointerEvents = 'auto';
      if (text) text.innerText = 'Putar di Speaker Sekolah';
    }, 4000);
    return true;
  }
</script>
  </div>
</div>

<style>
  .custom-audio-player::-webkit-media-controls-panel {
    background-color: #fff;
    border-radius: 1rem;
  }
  .dark .custom-audio-player::-webkit-media-controls-panel {
    background-color: #1e293b; /* slate-800 */
  }
</style>

<%- include('partials/footer') %>
