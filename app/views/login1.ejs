<%- include('layout') %>
<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow mt-10">
  <h2 class="text-2xl font-bold text-center mb-6">🔐 Login Admin</h2>
  <% if (locals.error) { %>
    <div class="bg-red-100 text-red-700 p-3 rounded mb-4"><%= locals.error %></div>
  <% } %>
  <form method="POST" action="/login">
    <div class="mb-4">
      <label class="block text-gray-700">Username</label>
      <input type="text" name="username" class="w-full px-4 py-2 border rounded" value="smamsa" required />
    </div>
    <div class="mb-6">
      <label class="block text-gray-700">Password</label>
      <input type="password" name="password" class="w-full px-4 py-2 border rounded" value="smamsa123" required />
    </div>
    <button type="submit" class="w-full bg-primary text-white py-2 rounded hover:bg-blue-700">
      Login
    </button>
  </form>
  <p class="text-center text-sm text-gray-500 mt-4">
    Default: admin / admin123 → ganti segera!
  </p>
</div>
