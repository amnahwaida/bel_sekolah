<%- include('layout') %>

<% if (locals.rename === "success") { %>
  <div class="bg-green-100 text-green-700 p-3 rounded mb-4"> ✅ Nama file berhasil diubah. </div>
<% } else if (locals.rename === "error") { %>
  <div class="bg-red-100 text-red-700 p-3 rounded mb-4"> ❌ Gagal mengganti nama. </div>
<% } %>
<% if (locals.stop === "success") { %>
  <div class="bg-green-100 text-green-700 p-3 rounded mb-4"> ✅ Pemutaran dihentikan. </div>
<% } %>
<% if (locals.import === "success") { %>
  <div class="bg-green-100 text-green-700 p-3 rounded mb-4"> ✅ Jadwal berhasil diimpor. </div>
<% } else if (locals.import === "error") { %>
  <div class="bg-red-100 text-red-700 p-3 rounded mb-4"> ❌ Gagal mengimpor jadwal. </div>
<% } %>

<div class="flex justify-between items-center mb-6">
      <div class="text-right mb-4">
        <a href="/logout" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded flex items-center">
          <span>🚪</span>
          <span class="ml-2">Logout</span>
        </a>
      </div>
  <h1 class="text-2xl font-bold">📊 Dashboard Bel Sekolah</h1>
  <div class="space-x-2">
    <a href="/export/schedules.json" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded text-sm">📤 Export Jadwal</a>
    <button onclick="document.getElementById('importForm').classList.toggle('hidden')" 
      class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm">📥 Import Jadwal</button>
  </div>
</div>

<!-- Toggle Jadwal Reguler -->
<div class="bg-white p-4 rounded shadow mb-6">
  <div class="flex items-center justify-between">
    <div>
      <h3 class="font-bold">🎛️ Pengaturan Jadwal Reguler</h3>
      <p class="text-sm text-gray-600">
        Matikan seluruh jadwal reguler (misal: libur). Jadwal khusus tetap aktif.
      </p>
    </div>
    <form method="POST" action="/schedule/toggle">
      <% if (locals.schedules && schedules.enabled) { %>
        <button type="submit" class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded flex items-center">
          <span>✅ AKTIF</span>
        </button>
      <% } else { %>
        <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded flex items-center">
          <span>❌ NONAKTIF</span>
        </button>
      <% } %>
    </form>
  </div>
</div>

<!-- Form Import -->
<div id="importForm" class="bg-white p-4 rounded shadow mb-6 hidden">
  <h3 class="font-bold mb-2">📤 Impor Jadwal dari File JSON</h3>
  <form method="POST" action="/import" enctype="multipart/form-data" class="flex gap-2">
    <input type="file" name="importfile" accept=".json" required class="flex-1" />
    <button type="submit" class="bg-blue-600 text-white px-3 rounded">Impor</button>
    <button type="button" onclick="document.getElementById('importForm').classList.add('hidden')"
      class="bg-gray-500 text-white px-3 rounded">×</button>
  </form>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Jadwal Reguler Per Hari -->
  <div class="bg-white p-6 rounded shadow">
    <h2 class="text-xl font-bold mb-4">⏰ Jadwal Reguler (Per Hari)</h2>
    <% const days = [
      { key: 'mon', name: 'Senin', bg: 'bg-blue-100', text: 'text-blue-800' },
      { key: 'tue', name: 'Selasa', bg: 'bg-green-100', text: 'text-green-800' },
      { key: 'wed', name: 'Rabu', bg: 'bg-yellow-100', text: 'text-yellow-800' },
      { key: 'thu', name: 'Kamis', bg: 'bg-purple-100', text: 'text-purple-800' },
      { key: 'fri', name: 'Jumat', bg: 'bg-red-100', text: 'text-red-800' },
      { key: 'sat', name: 'Sabtu', bg: 'bg-pink-100', text: 'text-pink-800' },
      { key: 'sun', name: 'Minggu', bg: 'bg-gray-100', text: 'text-gray-800' }
    ]; %>
    
    <% days.forEach(day => { %>
      <div class="mb-5">
        <h3 class="font-semibold flex items-center">
          <span class="<%= day.bg %> <%= day.text %> text-xs px-2 py-1 rounded mr-2"><%= day.name %></span>
        </h3>
        <ul class="space-y-1 mt-2">
          <% const list = schedules[day.key] || []; %>
          <% list.forEach((s, i) => { %>
            <li class="flex justify-between items-center bg-gray-50 p-2 rounded">
              <span class="font-mono"><%= s.time %> → <b><%= s.sound %></b></span>
              <form method="POST" action="/schedule/remove" class="inline">
                <input type="hidden" name="day" value="<%= day.key %>" />
                <input type="hidden" name="index" value="<%= i %>" />
                <button type="submit" class="text-red-500 hover:text-red-700">×</button>
              </form>
            </li>
          <% }) %>
          <% if (list.length === 0) { %>
            <li class="text-gray-400 italic">Belum ada jadwal</li>
          <% } %>
        </ul>
        <form method="POST" action="/schedule/add" class="mt-2 flex gap-2">
          <input type="hidden" name="day" value="<%= day.key %>" />
          <input type="time" name="time" class="px-2 py-1 border rounded" required />
          <select name="sound" class="px-2 py-1 border rounded" required>
            <% musicFiles.forEach(f => { %>
              <option value="<%= f %>"><%= f %></option>
            <% }) %>
          </select>
          <button type="submit" class="bg-green-500 text-white px-3 rounded text-sm">➕ Tambah</button>
        </form>
      </div>
    <% }) %>
  </div>

  <!-- Jadwal Khusus + Musik -->
  <div class="space-y-6">
    <div class="bg-white p-6 rounded shadow">
      <h2 class="text-xl font-bold mb-3">📅 Jadwal Khusus (Per Tanggal)</h2>
      <p class="text-sm text-gray-600 mb-2">
        ✅ Prioritas TERTINGGI: menggantikan jadwal reguler di tanggal tersebut.
      </p>
      <ul class="space-y-2">
        <% special.forEach((s, i) => { %>
          <li class="flex justify-between bg-blue-50 p-3 rounded">
            <div>
              <b class="text-blue-800"><%= s.date %></b> @ <span class="font-mono"><%= s.time %></span>
              <br><small>🎵 <%= s.sound %></small>
            </div>
            <form method="POST" action="/special/remove" class="inline">
              <input type="hidden" name="index" value="<%= i %>" />
              <button class="text-red-600">×</button>
            </form>
          </li>
        <% }) %>
        <% if (special.length === 0) { %>
          <li class="text-gray-400 italic">Belum ada jadwal khusus</li>
        <% } %>
      </ul>
      <form method="POST" action="/special/add" class="mt-4 flex flex-wrap gap-2">
        <input type="date" name="date" class="px-2 py-1 border rounded" required />
        <input type="time" name="time" class="px-2 py-1 border rounded" required />
        <select name="sound" class="px-2 py-1 border rounded" required>
          <% musicFiles.forEach(f => { %>
            <option value="<%= f %>"><%= f %></option>
          <% }) %>
        </select>
        <button type="submit" class="bg-blue-500 text-white px-3 rounded text-sm whitespace-nowrap">➕ Jadwal Khusus</button>
      </form>
    </div>

    <!-- Upload & STOP Global -->
    <div class="bg-white p-6 rounded shadow">
      <h2 class="text-xl font-bold mb-3">📤 Upload & Kontrol Musik</h2>
      <div class="mb-4 p-3 bg-orange-50 rounded flex items-center">
        <form method="POST" action="/stop" class="inline">
          <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white py-1 px-4 rounded text-sm flex items-center">
            <span>⏹️</span>
            <span class="ml-1">Hentikan Semua di STB</span>
          </button>
        </form>
        <% if (locals.stop === "success") { %>
          <span class="ml-3 text-green-600 text-sm">✅ Berhasil</span>
        <% } %>
      </div>
      <form method="POST" action="/upload" enctype="multipart/form-data" class="mb-4 p-3 bg-green-50 rounded">
        <input type="file" name="audiofile" accept=".mp3,.wav" class="mb-2" required />
        <button type="submit" class="bg-green-600 text-white py-1 px-3 rounded text-sm">
          📤 Upload MP3/WAV (max 20 MB)
        </button>
      </form>
      <h3 class="font-semibold mb-2">🎵 File Musik (<%= musicFiles.length %>)</h3>
      <div class="space-y-2 max-h-60 overflow-y-auto">
        <% musicFiles.forEach(f => { %>
          <div class="flex justify-between items-center border-b pb-1">
            <span class="font-mono text-sm text-gray-700"><%= f %></span>
            <div>
              <a href="/preview/<%= f %>" class="text-blue-600 hover:underline text-xs mr-2">🔊 Web</a>
              <form method="POST" action="/play" class="inline">
                <input type="hidden" name="file" value="<%= f %>" />
                <button type="submit" class="text-green-600 hover:text-green-800 text-xs">🎧 STB</button>
              </form>
              <form method="POST" action="/stop" class="inline ml-2">
                <button type="submit" class="text-orange-500 hover:text-orange-700 text-xs"
                  onclick="return confirm('Hentikan?')">🛑 Stop</button>
              </form>
              <form method="POST" action="/rename" class="inline ml-2">
                <input type="hidden" name="oldname" value="<%= f %>" />
                <input type="text" name="newname" value="<%= f %>" class="border text-xs px-1 w-32" maxlength="50"
                  onfocus="this.select()" onchange="if(!this.value.endsWith('.mp3') && !this.value.endsWith('.wav')) this.value += '.mp3'" />
                <button type="submit" class="text-blue-500 hover:text-blue-700 text-xs ml-1">✏️</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>
