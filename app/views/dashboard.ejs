                      <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
                    </svg>
                  </button>
                </form>
                <form method="POST" action="/rename" class="flex items-center gap-1 group/rename">
                  <input type="hidden" name="oldname" value="<%= f %>" />
                  <input type="text" name="newname" value="<%= f %>" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-[10px] px-2 py-1.5 rounded-lg w-24 focus:w-40 transition-all outline-none focus:border-blue-400 dark:focus:border-blue-500 text-slate-700 dark:text-slate-300" maxlength="50" onfocus="this.select()" />
                  <button type="submit" class="text-slate-300 dark:text-slate-600 hover:text-blue-500 dark:hover:text-blue-400 transition-colors" title="Ubah Nama">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                      <path d="M5.433 13.917l1.262-3.155A4 4 0 017.58 9.42l6.92-6.918a2.121 2.121 0 013 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 01-.65-.65z" />
                      <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0010 3H4.75A2.75 2.75 0 002 5.75v9.5A2.75 2.75 0 004.75 18h9.5A2.75 2.75 0 0017 15.25V10a.75.75 0 00-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5z" />
                    </svg>
                  </button>
                </form>
                <form method="POST" action="/music/delete" class="inline" onsubmit="return confirmDelete()">
                  <input type="hidden" name="file" value="<%= f %>" />
                  <button type="submit" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 flex items-center justify-center w-9 h-9 rounded-xl text-red-500 dark:text-red-400 hover:text-white hover:bg-red-500 hover:border-red-500 transition-all" title="Hapus">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                    </svg>
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out;
  }
  .animate-pulse-slow {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>

<!-- 🔊 Indikator Audio Sedang Diputar (Fixed) -->
<div id="nowPlayingIndicator" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-900/90 dark:bg-emerald-900/90 backdrop-blur-xl border border-slate-700 dark:border-emerald-500/30 px-6 py-4 rounded-3xl shadow-2xl z-50 transition-all duration-500 transform translate-y-32 opacity-0 flex items-center gap-4">
  <div class="relative">
    <div class="w-10 h-10 bg-emerald-500 rounded-full flex items-center justify-center animate-pulse shadow-[0_0_20px_rgba(16,185,129,0.5)]">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-white">
        <path d="M13.5 4.06c0-1.336-1.616-2.005-2.56-1.06l-4.5 4.5H4.508c-1.141 0-2.318.664-2.66 1.905A9.76 9.76 0 001.5 12c0 .898.121 1.768.35 2.595.341 1.24 1.518 1.905 2.659 1.905h1.93l4.5 4.5c.945.945 2.561.276 2.561-1.06V4.06zM18.584 5.106a.75.75 0 011.06 0c3.808 3.807 3.808 9.98 0 13.788a.75.75 0 11-1.06-1.06 8.25 8.25 0 000-11.668.75.75 0 010-1.06z" />
        <path d="M15.932 7.757a.75.75 0 011.061 0 4.5 4.5 0 010 6.364.75.75 0 01-1.06-1.06 3 3 0 000-4.242.75.75 0 010-1.062z" />
      </svg>
    </div>
    <div class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full border-2 border-slate-900 animate-ping"></div>
  </div>
  <div>
    <div class="text-[10px] font-black uppercase tracking-[0.2em] text-emerald-400 mb-0.5">Sedang Diputar</div>
    <div id="activeAudioName" class="text-white font-bold text-sm truncate max-w-[200px]">Memuat...</div>
  </div>
  <form method="POST" action="/stop" class="ml-2">
    <button type="submit" class="bg-red-500 hover:bg-red-600 text-white p-2 rounded-xl transition-all shadow-lg shadow-red-500/20 active:scale-95">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </form>
</div>
<script>
  let pollingInterval;
  let isProcessing = false;

  // =======================
  // LIVE MICROPHONE LOGIC
  // =======================
  const socket = io();
  const btnMic = document.getElementById('btnMic');
  const micPulse = document.getElementById('micPulse');
  const micStatusText = document.getElementById('micStatusText');
  const micStatusIcon = document.getElementById('micStatusIcon');
  
  let mediaRecorder = null;
  let isBroadcasting = false;

  async function startBroadcasting() {
    if (isBroadcasting) return;

    // Check for Secure Context (HTTPS/localhost)
    if (!window.isSecureContext) {
      alert('❌ ERROR KERTASAN/KEAMANAN:\n\n' +
            'Fitur Mikrofon mewajibkan koneksi aman (HTTPS). Browser Anda saat ini memblokir akses.\n\n' +
            'SOLUSI:\n' +
            '1. Pastikan URL dimulai dengan https://\n' +
            '2. Jika menggunakan Chrome lewat IP lokal, buka chrome://flags/#unsafely-treat-insecure-origin-as-secure\n' +
            '3. Masukkan alamat IP STB Anda di sana, ganti ke "Enabled", lalu relaunch.');
      return;
    }
    
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ 
        audio: {
          echoCancellation: true,
          noiseSuppression: true,
          autoGainControl: true
        } 
      });

      socket.emit('start-mic');
      
      socket.once('mic-ready', () => {
        isBroadcasting = true;
        
        // UI Feedback
        micPulse.classList.replace('opacity-0', 'opacity-50');
        micStatusText.textContent = "SEDANG SIARAN...";
        micStatusText.classList.add('text-purple-600', 'animate-pulse');
        micStatusIcon.classList.add('scale-110', 'bg-purple-100', 'dark:bg-purple-800');

        mediaRecorder = new MediaRecorder(stream, {
          mimeType: 'audio/webm;codecs=opus'
        });

        mediaRecorder.ondataavailable = async (e) => {
          if (e.data.size > 0 && socket.connected) {
            const buffer = await e.data.arrayBuffer();
            socket.emit('audio-data', buffer);
          }
        };

        // Send data every 100ms for low latency
        mediaRecorder.start(100);
      });

      socket.once('mic-error', (msg) => {
        alert('Gagal: ' + msg);
        stopBroadcasting();
      });

    } catch (err) {
      console.error('Mic Error:', err);
      alert('Tidak dapat mengakses mikrofon. Pastikan Anda menggunakan HTTPS atau localhost.');
    }
  }

  function stopBroadcasting() {
    if (!isBroadcasting) return;
    
    isBroadcasting = false;
    if (mediaRecorder) {
      mediaRecorder.stop();
      mediaRecorder.stream.getTracks().forEach(track => track.stop());
    }
    socket.emit('stop-mic');
    
    // UI Reset
    micPulse.classList.replace('opacity-50', 'opacity-0');
    micStatusText.textContent = "TAHAN UNTUK BICARA";
    micStatusText.classList.remove('text-purple-600', 'animate-pulse');
    micStatusIcon.classList.remove('scale-110', 'bg-purple-100', 'dark:bg-purple-800');
  }

  // Event Listeners for Push-to-Talk
  if (btnMic) {
    btnMic.addEventListener('mousedown', startBroadcasting);
    btnMic.addEventListener('mouseup', stopBroadcasting);
    btnMic.addEventListener('mouseleave', stopBroadcasting);
    
    // Support Touchevents for Mobile
    btnMic.addEventListener('touchstart', (e) => {
      e.preventDefault();
      startBroadcasting();
    });
    btnMic.addEventListener('touchend', (e) => {
      e.preventDefault();
      stopBroadcasting();
    });
  }

  function startPolling() {
    updateAmpliStatus();
    pollingInterval = setInterval(updateAmpliStatus, 2000);
  }

  // Update status amplifier
  async function updateAmpliStatus() {
    try {
      const response = await fetch('/ampli/status');
      const data = await response.json();
      
      const indicator = document.getElementById('relayStatusIndicator');
      const statusText = document.getElementById('relayStatusText');
      const btnOn = document.getElementById('btnAmpliOn');
      const btnOff = document.getElementById('btnAmpliOff');
      
      const nowPlaying = document.getElementById('nowPlayingIndicator');
      const activeName = document.getElementById('activeAudioName');

      if (data.relay === 'ON') {
        indicator.className = 'w-3 h-3 rounded-full bg-emerald-500 animate-pulse shadow-[0_0_10px_rgba(16,185,129,0.5)]';
        statusText.textContent = 'AKTIF';
        statusText.className = 'text-emerald-400 font-bold tracking-wide text-sm';
        btnOn.disabled = true;
        btnOff.disabled = false;
      } else {
        indicator.className = 'w-3 h-3 rounded-full bg-slate-600';
        statusText.textContent = 'NONAKTIF';
        statusText.className = 'text-slate-500 font-bold tracking-wide text-sm';
        btnOn.disabled = false;
        btnOff.disabled = true;
      }

      // Tampilkan info manual override
      if (data.manualOverride) {
        statusText.textContent += ' (MANUAL)';
      }

      // Handle Now Playing Indicator
      const playButtons = document.querySelectorAll('button[title="Putar Suara"]');
      if (data.audio && data.audio.isPlaying) {
        activeName.textContent = data.audio.activeFile || 'Tidak diketahui';
        nowPlaying.classList.remove('translate-y-32', 'opacity-0');
        nowPlaying.classList.add('translate-y-0', 'opacity-100');
        
        // Disable all play buttons
        playButtons.forEach(btn => {
          btn.disabled = true;
          btn.classList.add('opacity-50', 'cursor-not-allowed');
        });
      } else {
        nowPlaying.classList.add('translate-y-32', 'opacity-0');
        nowPlaying.classList.remove('translate-y-0', 'opacity-100');
        
        // Enable all play buttons
        playButtons.forEach(btn => {
          btn.disabled = false;
          btn.classList.remove('opacity-50', 'cursor-not-allowed');
        });
      }

    } catch (error) {
      console.error('Error fetching status:', error);
    }
  }

  // Kontrol amplifier ON/OFF
  async function controlAmpli(action) {
    if (isProcessing) return;
    
    isProcessing = true;
    const btnOn = document.getElementById('btnAmpliOn');
    const btnOff = document.getElementById('btnAmpliOff');
    
    btnOn.disabled = true;
    btnOff.disabled = true;

    try {
      const response = await fetch(`/ampli/${action}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      });

      const data = await response.json();
      
      if (data.success) {
        // Tampilkan notifikasi
        showNotification(`Amplifier ${action.toUpperCase()} berhasil!`, 'success');
        // Update status langsung
        setTimeout(updateAmpliStatus, 500);
      } else {
        showNotification('Gagal mengontrol amplifier', 'error');
      }
    } catch (error) {
      console.error('Error:', error);
      showNotification('Terjadi kesalahan', 'error');
    } finally {
      setTimeout(() => {
        isProcessing = false;
        updateAmpliStatus();
      }, 1000);
    }
  }

  // Helper: Tampilkan notifikasi
  function showNotification(message, type) {
    const container = document.createElement('div');
    container.className = `fixed top-4 right-4 p-4 rounded-lg shadow-lg z-50 ${
      type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
    }`;
    container.textContent = message;
    document.body.appendChild(container);
    
    setTimeout(() => {
      container.style.opacity = '0';
      container.style.transition = 'opacity 0.3s';
      setTimeout(() => container.remove(), 300);
    }, 3000);
  }

  // Toggle import form
  function toggleImportForm() {
    const form = document.getElementById('importForm');
    if (form) {
      form.classList.toggle('hidden');
    }
  }
  
  // Confirm before delete
  function confirmDelete() {
    return confirm('Apakah Anda yakin ingin menghapus?');
  }

  // Toggle Edit Schedule (Reguler)
  function toggleEditSchedule(day, index) {
    const viewEl = document.getElementById(`sched-view-${day}-${index}`);
    const editEl = document.getElementById(`sched-edit-${day}-${index}`);
    if (viewEl && editEl) {
      viewEl.classList.toggle('hidden');
      editEl.classList.toggle('hidden');
    }
  }

  // Toggle Edit Special Schedule
  function toggleEditSpecial(index) {
    const viewEl = document.getElementById(`special-view-${index}`);
    const editEl = document.getElementById(`special-edit-${index}`);
    if (viewEl && editEl) {
      viewEl.classList.toggle('hidden');
      editEl.classList.toggle('hidden');
    }
  }
  
  // Auto-hide success/error messages after 5 seconds
  document.addEventListener('DOMContentLoaded', function() {
    const messages = document.querySelectorAll('.bg-green-100, .bg-red-100, .bg-emerald-50, .bg-red-50');
    messages.forEach(msg => {
      setTimeout(() => {
        msg.style.opacity = '0';
        setTimeout(() => msg.remove(), 300);
      }, 5000);
    });
    
    // Start polling status amplifier
    startPolling();
  });
</script>

  <!-- Modal Quick Call -->
  <div id="modalQuickCall" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 animate-in fade-in duration-300">
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] w-full max-w-lg shadow-2xl border border-white/20 overflow-hidden transform transition-all animate-in zoom-in duration-300">
      <div class="p-8 text-center bg-gradient-to-br from-primary-600 to-indigo-700 text-white relative">
        <h3 class="text-2xl font-black mb-2 tracking-tight">Set Panggilan Ketua Kelas</h3>
        <p class="text-primary-100 text-sm font-medium opacity-80">Pilih suara yang akan dijadikan tombol pintasan</p>
        <button onclick="document.getElementById('modalQuickCall').classList.add('hidden')" class="absolute top-6 right-6 p-2 rounded-full hover:bg-white/10 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="p-8 max-h-[60vh] overflow-y-auto custom-scrollbar">
        <div class="space-y-3">
          <% musicFiles.forEach(file => { %>
            <% const isActive = (file === quickCallFile); %>
            <form method="POST" action="/config/quick-call">
              <input type="hidden" name="filename" value="<%= file %>">
              <button type="submit" 
                class="w-full p-4 rounded-2xl border transition-all group flex items-center justify-between
                <%= isActive ? 'border-primary-500 bg-primary-50/50 dark:bg-primary-900/20 shadow-sm shadow-primary-500/10' : 'border-slate-100 dark:border-slate-800 hover:border-primary-500/50 dark:hover:border-primary-500/50 hover:bg-slate-50 dark:hover:bg-slate-800/50' %>">
                <div class="flex flex-col items-start overflow-hidden">
                  <span class="text-sm font-bold truncate pr-4 transition-colors
                    <%= isActive ? 'text-primary-700 dark:text-primary-400' : 'text-slate-700 dark:text-slate-200 group-hover:text-primary-600 dark:group-hover:text-primary-400' %>">
                    <%= file %>
                  </span>
                  <% if (isActive) { %>
                    <span class="text-[9px] font-black uppercase tracking-widest text-primary-500 mt-0.5">Sedang Digunakan</span>
                  <% } %>
                </div>
                <div class="w-8 h-8 rounded-lg flex items-center justify-center transition-all shrink-0
                  <%= isActive ? 'bg-primary-600 text-white' : 'bg-slate-50 dark:bg-slate-800 text-slate-400 group-hover:bg-primary-100 dark:group-hover:bg-primary-800 group-hover:text-primary-600' %>">
                  <% if (isActive) { %>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                  <% } else { %>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                  <% } %>
                </div>
              </button>
            </form>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>
