            <span class="w-2.5 h-2.5 bg-red-500 rounded-full animate-pulse group-hover:animate-none"></span>
            STOP SEMUA AUDIO
          </button>
        </form>
      </div>

      <!-- Upload form integrated -->
      <form method="POST" action="/upload" enctype="multipart/form-data" class="mb-6 flex gap-2">
        <input type="file" name="audiofile" accept=".mp3,.wav" required class="flex-1 text-xs text-slate-500 dark:text-slate-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-[10px] file:font-black file:uppercase file:bg-emerald-50 dark:file:bg-emerald-900/40 file:text-emerald-700 dark:file:text-emerald-300 hover:file:bg-emerald-100 dark:hover:file:bg-emerald-800 transition-all p-2 border border-slate-100 dark:border-slate-700 rounded-2xl bg-transparent" />
        <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-lg shadow-emerald-500/20 flex items-center gap-2">
