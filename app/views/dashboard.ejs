                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.287a6 6 0 010 7.427M12 6.75l6.75 6.75-6.75 6.75V6.75z" />
                  </svg>
                </a>
                <form method="POST" action="/play" class="inline">
                  <input type="hidden" name="file" value="<%= f %>" />
                  <button type="submit" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 flex items-center justify-center w-9 h-9 rounded-xl text-emerald-600 dark:text-emerald-400 hover:text-white hover:bg-emerald-500 hover:border-emerald-500 transition-all" title="Play on STB">
