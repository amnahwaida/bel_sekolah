                <a href="/preview/<%= f %>" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 flex items-center justify-center w-9 h-9 rounded-xl text-blue-500 dark:text-blue-400 hover:text-white hover:bg-blue-500 hover:border-blue-500 transition-all" title="Preview Audio">
