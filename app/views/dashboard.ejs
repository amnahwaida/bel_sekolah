      <div class="flex-1 overflow-y-auto custom-scrollbar pr-2 max-h-[600px] transition-all">
        <div class="grid grid-cols-1 gap-3">
          <% musicFiles.forEach(f => { %>
            <div class="group flex flex-col md:flex-row justify-between items-start md:items-center p-4 rounded-2xl border border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/40 hover:bg-white dark:hover:bg-slate-800 hover:border-emerald-200 dark:hover:border-emerald-500/30 transition-all hover:shadow-sm w-full">
              <div class="flex items-center gap-3 mb-3 md:mb-0 min-w-0 flex-1 w-full md:w-auto">
                <div class="w-10 h-10 flex-shrink-0 bg-white dark:bg-slate-700 rounded-xl flex items-center justify-center text-slate-400 dark:text-slate-500 group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-all shadow-sm font-bold text-[10px] uppercase">
                  <%= f.split('.').pop() %>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="text-sm font-bold text-slate-700 dark:text-slate-200 truncate transition-colors" title="<%= f %>"><%= f %></div>
