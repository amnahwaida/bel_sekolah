<script src="/socket.io/socket.io.js"></script>

<%- include('partials/header', { activePage: 'dashboard' }) %>

<div class="max-w-[1400px] mx-auto pb-12">
  
  <!-- Page Header & Stats Row -->
  <div class="flex flex-col xl:flex-row justify-between items-start xl:items-center mb-16 gap-8 px-2">
    <div>
      <h1 class="text-5xl font-black text-white tracking-tighter flex items-center gap-5">
        <span class="w-3 h-12 bg-gradient-to-b from-primary-400 to-primary-700 rounded-full shadow-[0_0_20px_rgba(var(--primary-rgb),0.4)]"></span>
        Control Center
      </h1>
      <p class="text-slate-500 mt-3 font-medium text-lg leading-relaxed italic opacity-80">Monitoring real-time hardware dan kendali siaran langsung sekolah.</p>
    </div>
    
    <!-- System Status Badges -->
    <div class="flex flex-wrap gap-4">
      <div class="glass-premium px-6 py-4 rounded-3xl border border-white/5 flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl bg-primary-500/10 flex items-center justify-center text-primary-400">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div>
            <div class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Scheduler</div>
            <div class="text-white font-black text-sm uppercase"><%= schedules.enabled ? 'Running' : 'Paused' %></div>
        </div>
      </div>
      <div class="glass-premium px-6 py-4 rounded-3xl border border-white/5 flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl bg-orange-500/10 flex items-center justify-center text-orange-400">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5L14.25 2.25l-2.25 8.25h8.25L9.75 21.75l2.25-8.25H3.75z" />
            </svg>
        </div>
        <div>
            <div class="text-[9px] font-black text-slate-500 uppercase tracking-widest">STB Power</div>
            <div class="text-white font-black text-sm uppercase">Active</div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 1: HARDWARE & MONITORING -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Quick Call Card (Panggilan Cepat) (Mobile: 1, Desktop: 3) -->
    <div class="order-1 lg:order-3 glass-premium p-10 rounded-[3.5rem] border border-white/5 flex flex-col justify-between hover:border-accent/30 transition-all duration-500 relative overflow-hidden group">
      <div class="absolute -left-16 -bottom-16 w-64 h-64 bg-accent/20 rounded-full opacity-10 blur-[40px] pointer-events-none"></div>

      <div class="flex items-center gap-6 mb-10 relative z-10">
        <div class="w-16 h-16 bg-accent rounded-2xl text-white flex items-center justify-center shadow-2xl shadow-accent/30 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.287a6 6 0 010 7.427M12 18.75V5.25" />
          </svg>
        </div>
        <div>
          <h3 class="font-black text-white text-xl tracking-tight leading-none">Panggilan Cepat</h3>
          <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mt-2 italic">Aksi Instan</p>
        </div>
      </div>
      
      <div class="mt-auto w-full relative z-10">
        <% if (locals.quickCallFile) { %>
          <form method="POST" action="/play" id="quickCallForm" onsubmit="return handleQuickCallSubmit(this)">
            <input type="hidden" name="file" value="<%= quickCallFile %>">
            <button type="submit" id="btnQuickCall" class="w-full h-[88px] bg-accent hover:bg-accent/80 text-white rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.3em] transition-all shadow-xl shadow-accent/30 flex items-center justify-center gap-4 active:scale-95 group border-2 border-transparent">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 group-hover:scale-110 transition-transform" id="quickCallIcon">
                <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
              </svg>
              <span id="quickCallText">PANGGIL</span>
            </button>
          </form>
        <% } else { %>
          <a href="/audio" class="w-full h-[88px] bg-white/5 text-slate-500 rounded-[2.5rem] font-black text-[11px] uppercase flex items-center justify-center text-center border border-dashed border-white/10 hover:border-accent hover:text-accent transition-all italic tracking-[0.3em]">SET PANGGILAN</a>
        <% } %>
      </div>
    </div>

    <!-- Power Amplifier Hub (Mobile: 2, Desktop: 1) -->
    <div class="order-2 lg:order-1 glass-premium p-10 rounded-[3.5rem] border border-white/5 flex flex-col justify-between hover:border-primary-500/30 transition-all duration-500 relative overflow-hidden group">
      <div class="absolute -right-16 -top-16 w-64 h-64 bg-primary-600 rounded-full opacity-[0.03] blur-[40px] group-hover:opacity-[0.07] transition-opacity duration-1000 pointer-events-none"></div>

      <div class="flex items-center gap-6 mb-10 relative z-10">
        <div id="relayStatusRing" class="w-16 h-16 bg-slate-800 rounded-2xl border-[3px] border-slate-700 text-white flex items-center justify-center shadow-2xl transition-all duration-700 flex-shrink-0">
          <div id="relayStatusIndicator" class="w-3 h-3 rounded-full bg-slate-600 ring-4 ring-white/5 mx-auto transition-all duration-500"></div>
        </div>
        <div>
          <h3 class="font-black text-white text-xl tracking-tight leading-none">Power Amp</h3>
          <p id="relayStatusText" class="text-[10px] font-black text-slate-500 uppercase tracking-widest mt-2 italic">Status Unknown</p>
        </div>
      </div>
      
      <div class="mt-auto w-full relative z-10">
        <button id="btnAmpliToggle" onclick="toggleAmpliBtn()" class="w-full h-[88px] bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.3em] transition-all flex items-center justify-center gap-4 active:scale-95 border border-white/10">
          <span id="ampliToggleStatusDot" class="w-2 h-2 bg-slate-600 rounded-full"></span>
          <span id="ampliToggleText">MENUNGGU STATUS...</span>
        </button>
      </div>
    </div>

    <!-- Schedule Status Card (Mobile: 3, Desktop: 2) -->
    <div class="order-3 lg:order-2 glass-premium p-10 rounded-[3.5rem] border border-white/5 flex flex-col justify-between hover:border-primary-500/30 transition-all duration-500 relative overflow-hidden group">
      <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-primary-500/20 rounded-full opacity-[0.03] blur-[50px] pointer-events-none"></div>

      <div class="flex items-center gap-6 mb-10 relative z-10">
        <div class="w-16 h-16 bg-primary-600 rounded-2xl text-white flex items-center justify-center shadow-2xl shadow-primary-600/30 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h3 class="font-black text-white text-xl tracking-tight leading-none">Automasi Bel</h3>
          <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mt-2 italic">Scheduler Engine</p>
        </div>
      </div>
      
      <div class="mt-auto w-full relative z-10">
        <form method="POST" action="/schedule/toggle" onsubmit="return handleToggleSubmit(this)">
          <% if (locals.schedules && schedules.enabled) { %>
            <button type="submit" id="btnScheduleToggle" class="w-full h-[88px] bg-primary-500 hover:bg-primary-600 text-white rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.3em] transition-all shadow-xl shadow-primary-500/30 flex items-center justify-center gap-4 active:scale-95 group border-2 border-transparent">
              <span class="w-2 h-2 bg-white rounded-full animate-pulse" id="toggleDot"></span>
              <span id="toggleText">AKTIF</span>
            </button>
          <% } else { %>
            <button type="submit" id="btnScheduleToggle" class="w-full h-[88px] bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.3em] transition-all flex items-center justify-center gap-4 active:scale-95 border border-white/10">
              <span class="w-2 h-2 bg-slate-600 rounded-full" id="toggleDot"></span>
              <span id="toggleText">NONAKTIF</span>
            </button>
          <% } %>
        </form>
      </div>
    </div>
  </div>

  <!-- Live Microphone Widget -->
  <div class="mt-8">
      <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-primary-600 via-accent to-primary-400 rounded-[4.5rem] blur-2xl opacity-10 group-hover:opacity-30 transition duration-1000"></div>
          <div class="relative glass-premium p-12 lg:p-16 rounded-[4rem] border border-white/5 flex flex-col xl:flex-row items-center justify-between gap-12 shadow-2xl">
            <div class="flex items-center gap-10">
              <div id="micStatusIcon" class="w-24 h-24 bg-white/5 text-slate-400 flex items-center justify-center rounded-[2.5rem] transition-all duration-700 border border-white/5">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-12 h-12">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                </svg>
              </div>
              <div>
                <h3 class="font-black text-white text-4xl tracking-tighter mb-4 leading-none italic">Siaran Mikrofon</h3>
                <p id="micStatusText" class="text-sm font-black text-slate-500 uppercase tracking-[0.4em] italic leading-none">Push to Talk / Tahan Bicara</p>
              </div>
            </div>
  
            <div class="relative flex items-center justify-center">
              <div id="micPulse" class="absolute inset-0 rounded-full bg-accent animate-ping opacity-0"></div>
              <button id="btnMic" class="relative z-20 w-36 h-36 rounded-full bg-gradient-to-br from-primary-600 to-accent text-white flex items-center justify-center transition-all shadow-[0_25px_60px_rgba(var(--primary-rgb),0.4)] active:scale-90 select-none touch-none hover:scale-105 active:shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-16 h-16 transition-transform group-active:scale-110">
                  <path d="M8.25 4.5a3.75 3.75 0 117.5 0v8.25a3.75 3.75 0 11-7.5 0V4.5z" />
                  <path d="M6 10.5a.75.75 0 01.75.75v1.5a5.25 5.25 0 1010.5 0v-1.5a.75.75 0 011.5 0v1.5a6.75 6.75 0 11-13.5 0v-1.5a.75.75 0 01.75-.75z" />
                  <path d="M12 18.75a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V19.5a.75.75 0 01.75-.75z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
        
        <div class="mt-8 px-8 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
            </svg>
            <p class="text-[10px] font-black text-slate-600 uppercase tracking-widest italic leading-none">Fitur mikrofon memerlukan koneksi HTTPS atau localhost demi keamanan browser.</p>
      </div>
  </div>
</div>

<script>
  const socket = io();
  let isProcessing = false;

  const indicator = document.getElementById('relayStatusIndicator');
  const ring = document.getElementById('relayStatusRing');
  const text = document.getElementById('relayStatusText');
  const btnAmpliToggle = document.getElementById('btnAmpliToggle');
  const ampliToggleStatusDot = document.getElementById('ampliToggleStatusDot');
  const ampliToggleText = document.getElementById('ampliToggleText');
  let currentAmpliState = 'off';
  
  async function updateAmpliStatus() {
    try {
      const response = await fetch('/ampli/status');
      const data = await response.json();
      currentAmpliState = data.relay === 'ON' ? 'on' : 'off';
      
      // Jika server bilang relay sedang busy, tampilkan cooldown ke SEMUA user
      if (data.relayBusy && !isProcessing) {
        showCooldownState();
      } else if (!data.relayBusy && !isProcessing) {
        clearCooldownState();
      }
      
      if (currentAmpliState === 'on') {
        indicator.className = 'w-4 h-4 rounded-full bg-primary-400 shadow-[0_0_20px_rgba(var(--primary-rgb),0.5)] ring-4 ring-primary-400/20';
        ring.style.borderColor = 'var(--primary)';
        ring.style.boxShadow = 'inset 0 0 30px rgba(var(--primary-rgb),0.1), 0 0 30px rgba(var(--primary-rgb),0.1)';
        text.innerText = data.relayBusy ? '⏳ Cooldown...' : 'Power Active';
        text.className = 'text-primary-400 font-black tracking-[0.2em] text-[11px] uppercase';
        
        if (btnAmpliToggle && !isProcessing && !data.relayBusy) {
          btnAmpliToggle.className = 'w-full h-[88px] bg-primary-500 hover:bg-primary-600 text-white rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.3em] transition-all shadow-xl shadow-primary-500/30 flex items-center justify-center gap-4 active:scale-95 group border-2 border-transparent';
          ampliToggleStatusDot.className = 'w-2 h-2 bg-white rounded-full animate-pulse';
          ampliToggleText.innerText = 'AKTIF';
        }
      } else {
        indicator.className = 'w-4 h-4 rounded-full bg-slate-600 ring-4 ring-white/5';
        ring.style.borderColor = '#1e293b';
        ring.style.boxShadow = 'none';
        text.innerText = data.relayBusy ? '⏳ Cooldown...' : 'Standby Mode';
        text.className = 'text-slate-500 font-black tracking-[0.2em] text-[11px] uppercase';
        
        if (btnAmpliToggle && !isProcessing && !data.relayBusy) {
          btnAmpliToggle.className = 'w-full h-[88px] bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white rounded-[2.5rem] font-black text-[11px] uppercase tracking-[0.3em] transition-all flex items-center justify-center gap-4 active:scale-95 border border-white/10';
          ampliToggleStatusDot.className = 'w-2 h-2 bg-slate-600 rounded-full';
          ampliToggleText.innerText = 'NONAKTIF';
        }
      }
    } catch (err) {
      console.error(err);
    }
  }

  function showCooldownState() {
    if (!btnAmpliToggle) return;
    btnAmpliToggle.style.pointerEvents = 'none';
    btnAmpliToggle.classList.add('opacity-50');
    ampliToggleText.innerText = '⏳ COOLDOWN...';
    ampliToggleStatusDot.className = 'w-2 h-2 bg-amber-400 rounded-full animate-pulse';
  }

  function clearCooldownState() {
    if (!btnAmpliToggle) return;
    btnAmpliToggle.style.pointerEvents = 'auto';
    btnAmpliToggle.classList.remove('opacity-50');
  }

  // Start checking ampli status every 2s
  updateAmpliStatus();
  setInterval(updateAmpliStatus, 2000);

  function toggleAmpliBtn() {
    if (isProcessing || !btnAmpliToggle) return;
    isProcessing = true;
    
    // Tampilkan state cooldown di tombol
    showCooldownState();
    ampliToggleText.innerText = 'MEMPROSES...';
    
    const cmd = currentAmpliState === 'on' ? 'off' : 'on';
    fetch(`/ampli/${cmd}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    }).finally(() => {
      // Cooldown 2 detik selaras dengan backend debounce
      setTimeout(() => {
        isProcessing = false;
        clearCooldownState();
        updateAmpliStatus();
      }, 2000); 
    });
  }

  // Mic Logic (Push to Talk)
  const btnMic = document.getElementById('btnMic');
  const micPulse = document.getElementById('micPulse');
  const micStatusText = document.getElementById('micStatusText');
  const micStatusIcon = document.getElementById('micStatusIcon');
  let mediaRecorder;
  let isBroadcasting = false;

  async function startBroadcasting() {
    if (isBroadcasting || !window.isSecureContext) {
        if (!window.isSecureContext) showToast('Mic requires Secure Context (HTTPS)', 'error');
        return;
    }
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      socket.emit('start-mic');

      // Handlers for mic logic
      socket.once('mic-ready', () => {
        isBroadcasting = true;
        micPulse.classList.replace('opacity-0', 'opacity-100');
        micStatusText.innerText = 'ON AIR';
        micStatusText.classList.replace('text-slate-500', 'text-rose-500');
        micStatusIcon.classList.add('bg-rose-500/20', 'text-rose-500', 'border-rose-500/30');
        micStatusIcon.classList.add('scale-110');
        mediaRecorder = new MediaRecorder(stream, { mimeType: 'audio/webm;codecs=opus' });
        mediaRecorder.ondataavailable = async (e) => { if (e.data.size > 0) socket.emit('audio-data', await e.data.arrayBuffer()); };
        mediaRecorder.start(100);
      });

      socket.once('mic-error', (msg) => {
        if (typeof showToast === 'function') showToast(msg, 'error');
        else alert('Error: ' + msg);
        
        // Cleanup lokal
        stream.getTracks().forEach(t => t.stop());
        isBroadcasting = false;
        
        // Lepas event listener mic-ready agar tidak dipanggil di masa depan secara tumpang tindih
        socket.off('mic-ready');
      });

    } catch (err) {
        if (typeof showToast === 'function') showToast('Microphone access denied', 'error');
        else alert('Microphone access denied');
    }
  }

  function stopBroadcasting() {
    if (!isBroadcasting) return;
    isBroadcasting = false;
    if (mediaRecorder) { mediaRecorder.stop(); mediaRecorder.stream.getTracks().forEach(t => t.stop()); }
    socket.emit('stop-mic');
    micPulse.classList.replace('opacity-100', 'opacity-0');
    micStatusText.innerText = 'TAHAN UNTUK BICARA';
    micStatusText.classList.replace('text-rose-500', 'text-slate-500');
    micStatusIcon.classList.remove('bg-rose-500/20', 'text-rose-500', 'border-rose-500/30', 'scale-110');
  }

  if (btnMic) {
    btnMic.addEventListener('mousedown', startBroadcasting);
    btnMic.addEventListener('mouseup', stopBroadcasting);
    btnMic.addEventListener('mouseleave', stopBroadcasting);
    btnMic.addEventListener('touchstart', (e) => { e.preventDefault(); startBroadcasting(); });
    btnMic.addEventListener('touchend', (e) => { e.preventDefault(); stopBroadcasting(); });
  }
  // === ANTI-SPAM: Quick Call ===
  function handleQuickCallSubmit(form) {
    const btn = form.querySelector('#btnQuickCall');
    const text = form.querySelector('#quickCallText');
    if (btn.disabled) return false;
    btn.disabled = true;
    btn.classList.add('opacity-50');
    btn.style.pointerEvents = 'none';
    text.innerText = '⏳ MEMPROSES...';
    // Auto re-enable setelah 4 detik (jika redirect gagal)
    setTimeout(() => {
      btn.disabled = false;
      btn.classList.remove('opacity-50');
      btn.style.pointerEvents = 'auto';
      text.innerText = 'PANGGIL';
    }, 4000);
    return true;
  }

  // === ANTI-SPAM: Schedule Toggle ===
  function handleToggleSubmit(form) {
    const btn = form.querySelector('#btnScheduleToggle');
    const text = form.querySelector('#toggleText');
    const dot = form.querySelector('#toggleDot');
    if (btn.disabled) return false;
    btn.disabled = true;
    btn.classList.add('opacity-50');
    btn.style.pointerEvents = 'none';
    if (text) text.innerText = '⏳ MEMPROSES...';
    if (dot) dot.className = 'w-2 h-2 bg-amber-400 rounded-full animate-pulse';
    // Auto re-enable setelah 3 detik (jika redirect gagal)
    setTimeout(() => {
      btn.disabled = false;
      btn.classList.remove('opacity-50');
      btn.style.pointerEvents = 'auto';
    }, 3000);
    return true;
  }
</script>

<%- include('partials/footer') %>
