<script src="/socket.io/socket.io.js"></script>

<%- include('partials/header') %>

<div id="flash-messages">
  <% if (locals.rename === "success") { %>
    <div class="bg-green-50 border border-green-200 text-green-700 p-4 rounded-2xl mb-6 shadow-sm flex items-center gap-3 animate-fade-in">
      <span class="bg-green-500 text-white p-1 rounded-full text-xs">✓</span> Nama file berhasil diubah.
    </div>
  <% } else if (locals.rename === "error") { %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-2xl mb-6 shadow-sm flex items-center gap-3 animate-fade-in">
      <span class="bg-red-500 text-white p-1 rounded-full text-xs">✕</span> Gagal mengganti nama.
    </div>
  <% } %>
  <% if (locals.stop === "success") { %>
    <div class="bg-blue-50 border border-blue-200 text-blue-700 p-4 rounded-2xl mb-6 shadow-sm flex items-center gap-3 animate-fade-in">
      <span class="bg-blue-500 text-white p-1 rounded-full text-xs">i</span> Pemutaran dihentikan.
    </div>
  <% } %>
  <% if (locals.import === "success") { %>
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 p-4 rounded-2xl mb-6 shadow-sm flex items-center gap-3 animate-fade-in">
      <span class="bg-emerald-500 text-white p-1 rounded-full text-xs">✓</span> Jadwal berhasil diimpor.
    </div>
  <% } else if (locals.import === "error") { %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-2xl mb-6 shadow-sm flex items-center gap-3 animate-fade-in">
      <span class="bg-red-500 text-white p-1 rounded-full text-xs">✕</span> Gagal mengimpor jadwal.
    </div>
  <% } %>
</div>

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-6">
  <div>
    <h1 class="text-3xl font-bold text-slate-800 dark:text-slate-100 transition-colors flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-primary-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
      </svg>
      Dashboard Kontrol
    </h1>
    <p class="text-slate-500 dark:text-slate-400 mt-1 ml-11">Kelola jadwal dan bel sekolah dengan mudah.</p>
  </div>
  <div class="flex flex-wrap gap-3">
    <a href="/export/schedules.json" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 hover:border-emerald-300 dark:hover:border-emerald-500 hover:text-emerald-600 dark:hover:text-emerald-400 text-slate-600 dark:text-slate-400 px-5 py-2.5 rounded-xl font-semibold transition-all shadow-sm flex items-center group">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
      </svg>
      <span>Export</span>
    </a>
    <button onclick="toggleImportForm()"
      class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 hover:border-blue-300 dark:hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 text-slate-600 dark:text-slate-400 px-5 py-2.5 rounded-xl font-semibold transition-all shadow-sm flex items-center group">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      <span>Import</span>
    </button>
  </div>
</div>

<!-- 🔌 Kontrol Manual Amplifier -->
<div class="bg-gradient-to-br from-slate-900 to-slate-800 dark:from-slate-900 dark:to-black p-8 rounded-3xl shadow-xl shadow-slate-200 dark:shadow-none mb-8 border border-slate-700 relative overflow-hidden transition-all">
  <div class="absolute -right-12 -top-12 w-48 h-48 bg-primary-600 rounded-full opacity-10 blur-3xl"></div>
  <div class="absolute -left-12 -bottom-12 w-48 h-48 bg-accent rounded-full opacity-10 blur-3xl"></div>
  
  <div class="flex flex-col lg:flex-row items-center justify-between gap-8 relative z-10">
    <div class="text-center lg:text-left">
      <h3 class="text-white text-2xl font-bold mb-2 flex items-center justify-center lg:justify-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-primary-400">
          <path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.982 9.75h7.268a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.75a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 01.913-.143z" clip-rule="evenodd" />
        </svg>
        Power Amplifier
      </h3>
      <p class="text-slate-400 text-sm">Status aktual perangkat keras relay pembantu.</p>
    </div>
    
    <div class="flex flex-col sm:flex-row items-center gap-6">
      <div class="bg-slate-800/50 dark:bg-black/40 px-6 py-3 rounded-2xl border border-slate-700 flex items-center gap-3 shadow-inner">
        <div id="relayStatusIndicator" class="w-3 h-3 rounded-full bg-slate-600"></div>
        <span id="relayStatusText" class="text-white font-bold tracking-wide text-sm whitespace-nowrap">LOADING...</span>
      </div>
      
      <div class="flex gap-3 bg-slate-800/50 p-1.5 rounded-2xl border border-slate-700">
        <button id="btnAmpliOn" onclick="controlAmpli('on')" 
                class="bg-emerald-500 hover:bg-emerald-600 text-white px-8 py-3 rounded-xl font-bold transition-all hover:shadow-lg hover:shadow-emerald-500/30 active:scale-95 disabled:opacity-30 disabled:hover:shadow-none">
          ON
        </button>
        <button id="btnAmpliOff" onclick="controlAmpli('off')" 
                class="bg-red-500 hover:bg-red-600 text-white px-8 py-3 rounded-xl font-bold transition-all hover:shadow-lg hover:shadow-red-500/30 active:scale-95 disabled:opacity-30 disabled:hover:shadow-none">
          OFF
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Toggle Jadwal Reguler -->
<div class="glass p-6 rounded-3xl mb-8 border-slate-200 dark:border-slate-800 shadow-sm transition-all">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <div class="bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 p-3 rounded-2xl transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 13.5V3.75m0 9.75a1.5 1.5 0 010 3m0-3a1.5 1.5 0 000 3m0 3.75V16.5m12-3V3.75m0 9.75a1.5 1.5 0 010 3m0-3a1.5 1.5 0 000 3m0 3.75V16.5m-6-9V3.75m0 3.75a1.5 1.5 0 010 3m0-3a1.5 1.5 0 000 3m0 9.75V10.5" />
        </svg>
      </div>
      <div>
        <h3 class="font-bold text-slate-800 dark:text-slate-100 transition-colors">Status Penjadwalan</h3>
        <p class="text-xs text-slate-500 dark:text-slate-400">Operasi otomatis bel harian.</p>
      </div>
    </div>
    <form method="POST" action="/schedule/toggle">
      <% if (locals.schedules && schedules.enabled) { %>
        <button type="submit" class="bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800/30 px-6 py-2 rounded-xl font-bold hover:bg-emerald-200 dark:hover:bg-emerald-900/50 transition-colors flex items-center gap-2">
          <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
          AKTIF
        </button>
      <% } else { %>
        <button type="submit" class="bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 px-6 py-2 rounded-xl font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors flex items-center gap-2">
          <span class="w-2 h-2 bg-slate-400 rounded-full"></span>
          NONAKTIF
        </button>
      <% } %>
    </form>
  </div>
</div>

<!-- Form Import -->
<div id="importForm" class="bg-white dark:bg-slate-900 p-6 rounded-3xl border border-blue-100 dark:border-blue-900/40 shadow-xl shadow-blue-500/5 mb-8 hidden transition-all">
  <h3 class="font-bold text-slate-800 dark:text-slate-100 mb-4 flex items-center gap-2 transition-colors">
    <span class="text-blue-500">📥</span> Import Konfigurasi
  </h3>
  <form method="POST" action="/import" enctype="multipart/form-data" class="flex flex-col sm:flex-row gap-4">
    <input type="file" name="importfile" accept=".json" required class="flex-1 p-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 dark:file:bg-blue-900/30 file:text-blue-700 dark:file:text-blue-400 hover:file:bg-blue-100 dark:hover:file:bg-blue-800 bg-transparent text-slate-500 dark:text-slate-400 transition-all" />
    <div class="flex gap-2">
      <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700 font-bold transition-all shadow-lg shadow-blue-500/20">Proses</button>
      <button type="button" onclick="toggleImportForm()"
        class="bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 px-6 py-3 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 font-bold transition-all">Batal</button>
    </div>
  </form>
</div>

  <!-- 🚀 AKSI CEPAT (Quick Actions) -->
  <div class="mb-10 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <div class="flex items-center gap-2 mb-4 ml-2">
      <div class="w-1.5 h-6 bg-primary-600 dark:bg-primary-500 rounded-full transition-all"></div>
      <h2 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 transition-colors">Aksi Cepat (Panggilan)</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Card Panggilan Ketua Kelas -->
      <div class="relative group">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-primary-600 to-indigo-600 rounded-[2rem] blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 p-6 rounded-[2rem] shadow-sm flex items-center justify-between gap-4 transition-all">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-primary-50 dark:bg-primary-900/30 rounded-2xl flex items-center justify-center text-primary-600 dark:text-primary-400 transition-all group-hover:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.062.51.111.769.148m-.769-.148a20.247 20.247 0 010-9.04m.769 9.188a10.175 10.175 0 005.139 1.856m-5.139-1.856c.253.063.51.111.769.148m4.37 1.708l3.111 2.333a1.125 1.125 0 001.765-.901v-8.333a1.125 1.125 0 00-1.765-.901l-3.111 2.333m0 6.066a10.175 10.175 0 005.139-1.856m-5.139 1.856a10.137 10.137 0 01-4.37-1.708m0-6.066a10.137 10.137 0 014.37-1.708m-4.37 1.708a10.27 10.27 0 010 6.066m3.374 3.033A1.125 1.125 0 0115 19.125v-1.125" />
              </svg>
            </div>
            <div>
              <h3 class="font-black text-slate-800 dark:text-slate-100 text-sm tracking-tight transition-colors">Ketua Kelas</h3>
              <p class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase tracking-widest mt-0.5">Panggilan Cepat</p>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <% if (quickCallFile) { %>
              <form method="POST" action="/play" class="inline">
                <input type="hidden" name="file" value="<%= quickCallFile %>">
                <button type="submit" class="w-12 h-12 rounded-xl bg-primary-600 hover:bg-primary-700 text-white flex items-center justify-center transition-all shadow-lg shadow-primary-500/30 active:scale-90" title="Panggil Sekarang">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                    <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
                  </svg>
                </button>
              </form>
              <button onclick="document.getElementById('modalQuickCall').classList.remove('hidden')" class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-slate-400 hover:text-primary-500 transition-all border border-slate-100 dark:border-slate-700 shadow-sm" title="Ganti Suara">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0m-9.75 0h9.75" />
                </svg>
              </button>
            <% } else { %>
              <button onclick="document.getElementById('modalQuickCall').classList.remove('hidden')" class="bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-lg shadow-primary-500/20 active:scale-95 leading-none">
                SET PINTASAN
              </button>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Card Pengumuman Langsung (Mic) -->
      <div id="micWidget" class="relative group">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-pink-600 rounded-[2rem] blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 p-6 rounded-[2rem] shadow-sm flex items-center justify-between gap-4 transition-all">
          <div class="flex items-center gap-4">
            <div id="micStatusIcon" class="w-14 h-14 bg-purple-50 dark:bg-purple-900/30 rounded-2xl flex items-center justify-center text-purple-600 dark:text-purple-400 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
              </svg>
            </div>
            <div>
              <h3 class="font-black text-slate-800 dark:text-slate-100 text-sm tracking-tight transition-colors">Siaran Langsung</h3>
              <p id="micStatusText" class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase tracking-widest mt-0.5 whitespace-nowrap">Tahan Untuk Bicara</p>
            </div>
          </div>

          <div class="relative">
            <button 
              id="btnMic"
              class="w-16 h-16 rounded-full bg-purple-600 hover:bg-purple-500 text-white flex items-center justify-center transition-all shadow-lg shadow-purple-500/30 active:scale-90 select-none touch-none"
              title="Tahan untuk Bicara"
            >
              <div id="micPulse" class="absolute inset-0 rounded-full bg-purple-400 animate-ping opacity-0"></div>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 relative z-10">
                <path d="M8.25 4.5a3.75 3.75 0 117.5 0v8.25a3.75 3.75 0 11-7.5 0V4.5z" />
                <path d="M6 10.5a.75.75 0 01.75.75v1.5a5.25 5.25 0 1010.5 0v-1.5a.75.75 0 011.5 0v1.5a6.75 6.75 0 11-13.5 0v-1.5a.75.75 0 01.75-.75z" />
                <path d="M12 18.75a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V19.5a.75.75 0 01.75-.75z" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

<div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
  <!-- Jadwal Reguler Per Hari -->
  <div class="xl:col-span-12">
    <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm transition-all">
      <h2 class="text-2xl font-bold mb-6 text-slate-800 dark:text-slate-100 flex items-center gap-3 transition-colors">
        <span class="p-2 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-xl transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        Jadwal Reguler Mingguan
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-6">
        <% const days = [
          { key: 'mon', name: 'Senin', color: 'blue' },
          { key: 'tue', name: 'Selasa', color: 'indigo' },
          { key: 'wed', name: 'Rabu', color: 'violet' },
          { key: 'thu', name: 'Kamis', color: 'purple' },
          { key: 'fri', name: 'Jumat', color: 'emerald' },
          { key: 'sat', name: 'Sabtu', color: 'orange' },
          { key: 'sun', name: 'Minggu', color: 'rose' }
        ]; %>

        <% days.forEach(day => { %>
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-700/50 flex flex-col hover:border-<%= day.color %>-200 dark:hover:border-<%= day.color %>-500/30 transition-all group/day">
            <h3 class="font-bold mb-4 text-<%= day.color %>-600 dark:text-<%= day.color %>-400 flex items-center justify-between transition-colors">
              <span><%= day.name %></span>
              <span class="text-[10px] bg-<%= day.color %>-100 dark:bg-<%= day.color %>-900/30 px-2 py-1 rounded-full uppercase tracking-wider text-<%= day.color %>-700 dark:text-<%= day.color %>-300 transition-colors"><%= day.key %></span>
            </h3>
            
            <ul class="space-y-2 mb-4 flex-1">
              <% const list = schedules[day.key] || []; %>
              <% list.forEach((s, i) => { %>
                <!-- View Mode -->
                <li id="sched-view-<%= day.key %>-<%= i %>" class="group flex justify-between items-center bg-white dark:bg-slate-800 p-3 rounded-xl border border-slate-100 dark:border-slate-700 hover:border-<%= day.color %>-200 dark:hover:border-<%= day.color %>-500/30 hover:shadow-sm transition-all">
                  <div class="flex flex-col min-w-0 flex-1">
                    <span class="text-sm font-bold text-slate-700 dark:text-slate-200 leading-tight transition-colors"><%= s.time %></span>
                    <span class="text-[10px] text-slate-400 dark:text-slate-500 truncate max-w-full transition-colors" title="<%= s.sound %>"><%= s.sound %></span>
                  </div>
                  <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
                    <button type="button" onclick="toggleEditSchedule('<%= day.key %>', <%= i %>)" class="bg-blue-50 dark:bg-blue-900/20 text-blue-500 dark:text-blue-400 hover:bg-blue-500 dark:hover:bg-blue-500 hover:text-white w-7 h-7 rounded-lg flex items-center justify-center transition-all" title="Edit">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                        <path d="M5.433 13.917l1.262-3.155A4 4 0 017.58 9.42l6.92-6.918a2.121 2.121 0 013 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 01-.65-.65z" />
                      </svg>
                    </button>
                    <form method="POST" action="/schedule/remove" class="inline" onsubmit="return confirmDelete()">
                      <input type="hidden" name="day" value="<%= day.key %>" />
                      <input type="hidden" name="index" value="<%= i %>" />
                      <button type="submit" class="bg-red-50 dark:bg-red-900/20 text-red-500 dark:text-red-400 hover:bg-red-500 dark:hover:bg-red-500 hover:text-white w-7 h-7 rounded-lg flex items-center justify-center transition-all" title="Hapus">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                          <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                        </svg>
                      </button>
                    </form>
                  </div>
                </li>
                <!-- Edit Mode (hidden by default) -->
                <li id="sched-edit-<%= day.key %>-<%= i %>" class="hidden">
                  <form method="POST" action="/schedule/edit" class="bg-<%= day.color %>-50/50 dark:bg-<%= day.color %>-900/10 p-3 rounded-xl border border-<%= day.color %>-200 dark:border-<%= day.color %>-700/50 space-y-2">
                    <input type="hidden" name="day" value="<%= day.key %>" />
                    <input type="hidden" name="index" value="<%= i %>" />
                    <div class="flex gap-2">
                      <input type="time" name="time" value="<%= s.time %>" class="px-2 py-1.5 text-xs border border-slate-200 dark:border-slate-700 rounded-lg flex-1 outline-none focus:border-<%= day.color %>-400 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300" required />
                      <select name="sound" class="px-2 py-1.5 text-xs border border-slate-200 dark:border-slate-700 rounded-lg flex-1 min-w-0 outline-none focus:border-<%= day.color %>-400 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 truncate" required>
                        <% musicFiles.forEach(f => { %>
                          <option value="<%= f %>" <%= f === s.sound ? 'selected' : '' %>><%= f %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="flex gap-2">
                      <button type="submit" class="flex-1 bg-<%= day.color %>-600 hover:bg-<%= day.color %>-700 text-white py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-widest transition-all">Simpan</button>
                      <button type="button" onclick="toggleEditSchedule('<%= day.key %>', <%= i %>)" class="px-3 py-1.5 bg-slate-100 dark:bg-slate-800 text-slate-500 rounded-lg text-[10px] font-bold uppercase tracking-widest hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">Batal</button>
                    </div>
                  </form>
                </li>
              <% }) %>
              <% if (list.length === 0) { %>
                <li class="text-slate-400 dark:text-slate-600 text-xs italic py-4 text-center border border-dashed border-slate-200 dark:border-slate-700 rounded-xl transition-colors">Belum ada jadwal</li>
              <% } %>
            </ul>

            <form method="POST" action="/schedule/add" class="mt-auto pt-4 border-t border-slate-200/50 dark:border-slate-700/50 flex flex-col gap-2">
              <input type="hidden" name="day" value="<%= day.key %>" />
              <div class="flex gap-2">
                <input type="time" name="time" class="px-2 py-1 text-xs border border-slate-200 dark:border-slate-700 rounded-lg flex-1 outline-none focus:border-<%= day.color %>-300 dark:focus:border-<%= day.color %>-500 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 transition-all" required />
                <select name="sound" class="px-2 py-1 text-xs border border-slate-200 dark:border-slate-700 rounded-lg flex-1 min-w-0 outline-none focus:border-<%= day.color %>-300 dark:focus:border-<%= day.color %>-500 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 transition-all truncate" required>
                  <% musicFiles.forEach(f => { %>
                    <option value="<%= f %>"><%= f %></option>
                  <% }) %>
                </select>
              </div>
              <button type="submit" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:bg-slate-800 dark:hover:bg-slate-700 hover:text-white dark:hover:text-white text-slate-600 dark:text-slate-400 py-2 rounded-lg text-[10px] font-bold uppercase tracking-widest transition-all">
                Tambah Jadwal
              </button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Row 2: Special Schedules and Music -->
  <div class="xl:col-span-5">
    <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm h-full transition-all">
      <h2 class="text-2xl font-bold mb-6 text-slate-800 dark:text-slate-100 flex items-center gap-3 transition-colors">
        <span class="p-2 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-xl transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
          </svg>
        </span>
        Jadwal Khusus
      </h2>
      
      <ul class="space-y-3 mb-8 pr-2 transition-all">
        <% special.forEach((s, i) => { %>
          <!-- View Mode -->
          <li id="special-view-<%= i %>" class="flex items-center justify-between bg-slate-50 dark:bg-slate-800 p-4 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-indigo-200 dark:hover:border-indigo-500/30 transition-all group">
            <div class="flex items-center gap-3 min-w-0 flex-1">
              <div class="bg-white dark:bg-slate-700 p-2 rounded-xl text-center shadow-sm min-w-[60px] shrink-0 transition-colors">
                <div class="text-[10px] text-slate-400 dark:text-slate-500 uppercase font-bold tracking-tighter transition-colors"><%= s.date.split('-')[0] %></div>
                <div class="text-sm font-bold text-indigo-600 dark:text-indigo-400 transition-colors"><%= s.date.split('-')[1] %>-<%= s.date.split('-')[2] %></div>
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-sm font-bold text-slate-700 dark:text-slate-200 transition-colors"><%= s.time %></div>
                <div class="text-[10px] text-slate-400 dark:text-slate-500 truncate max-w-full transition-colors" title="<%= s.sound %>"><%= s.sound %></div>
              </div>
            </div>
            <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
              <button type="button" onclick="toggleEditSpecial(<%= i %>)" class="bg-blue-50 dark:bg-blue-900/20 text-blue-500 dark:text-blue-400 hover:bg-blue-500 hover:text-white w-8 h-8 rounded-xl flex items-center justify-center transition-all" title="Edit">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                  <path d="M5.433 13.917l1.262-3.155A4 4 0 017.58 9.42l6.92-6.918a2.121 2.121 0 013 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 01-.65-.65z" />
                </svg>
              </button>
              <form method="POST" action="/special/remove" class="inline" onsubmit="return confirmDelete()">
                <input type="hidden" name="index" value="<%= i %>" />
                <button class="bg-red-50 dark:bg-red-900/20 text-red-500 dark:text-red-400 hover:bg-red-500 hover:text-white w-8 h-8 rounded-xl flex items-center justify-center transition-all" title="Hapus">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                  </svg>
                </button>
              </form>
            </div>
          </li>
          <!-- Edit Mode (hidden by default) -->
          <li id="special-edit-<%= i %>" class="hidden">
            <form method="POST" action="/special/edit" class="bg-indigo-50/50 dark:bg-indigo-900/10 p-4 rounded-2xl border border-indigo-200 dark:border-indigo-700/50 space-y-3">
              <input type="hidden" name="index" value="<%= i %>" />
              <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                  <label class="text-[10px] text-slate-400 font-bold uppercase px-1">Tanggal</label>
                  <input type="date" name="date" value="<%= s.date %>" class="px-3 py-2 text-sm border border-slate-200 dark:border-slate-700 rounded-xl w-full outline-none focus:border-indigo-400 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 relative z-10" required />
                </div>
                <div class="flex flex-col gap-1">
                  <label class="text-[10px] text-slate-400 font-bold uppercase px-1">Jam</label>
                  <input type="time" name="time" value="<%= s.time %>" class="px-3 py-2 text-sm border border-slate-200 dark:border-slate-700 rounded-xl w-full outline-none focus:border-indigo-400 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 relative z-10" required />
                </div>
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase px-1">Pilih Suara</label>
                <select name="sound" class="px-3 py-2 text-sm border border-slate-200 dark:border-slate-700 rounded-xl w-full outline-none focus:border-indigo-400 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 truncate" required>
                  <% musicFiles.forEach(f => { %>
                    <option value="<%= f %>" <%= f === s.sound ? 'selected' : '' %>><%= f %></option>
                  <% }) %>
                </select>
              </div>
              <div class="flex gap-2">
                <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 rounded-xl transition-all shadow-lg shadow-indigo-600/20">Simpan</button>
                <button type="button" onclick="toggleEditSpecial(<%= i %>)" class="px-4 py-2.5 bg-slate-100 dark:bg-slate-800 text-slate-500 rounded-xl font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">Batal</button>
              </div>
            </form>
          </li>
        <% }) %>
        <% if (special.length === 0) { %>
          <li class="text-slate-400 dark:text-slate-600 italic py-12 text-center border border-dashed border-slate-200 dark:border-slate-700 rounded-2xl transition-colors">
            Belum ada jadwal khusus per tanggal
          </li>
        <% } %>
      </ul>

      <div class="bg-indigo-50/50 dark:bg-indigo-900/10 p-6 rounded-2xl border border-indigo-100 dark:border-indigo-900/40 transition-colors relative z-20">
        <h4 class="text-xs font-bold text-indigo-700 dark:text-indigo-400 uppercase tracking-widest mb-4 transition-colors">Tambah Jadwal Baru</h4>
        <form method="POST" action="/special/add" class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1">
              <label class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase px-1 transition-colors">Tanggal</label>
              <input type="date" name="date" class="px-3 py-2 text-sm border border-slate-200 dark:border-slate-700 rounded-xl w-full outline-none focus:border-indigo-400 dark:focus:border-indigo-500 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 transition-all relative z-10" required />
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase px-1 transition-colors">Jam</label>
              <input type="time" name="time" class="px-3 py-2 text-sm border border-slate-200 dark:border-slate-700 rounded-xl w-full outline-none focus:border-indigo-400 dark:focus:border-indigo-500 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 transition-all relative z-10" required />
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase px-1 transition-colors">Pilih Suara</label>
            <select name="sound" class="px-3 py-2 text-sm border border-slate-200 dark:border-slate-700 rounded-xl w-full outline-none focus:border-indigo-400 dark:focus:border-indigo-500 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 transition-all truncate" required>
              <% musicFiles.forEach(f => { %>
                <option value="<%= f %>"><%= f %></option>
              <% }) %>
            </select>
          </div>
          <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-indigo-600/20 active:scale-[0.98]">
            Simpan Jadwal Khusus
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Music Section -->
  <div class="xl:col-span-7">
    <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm h-full flex flex-col transition-all">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-800 dark:text-slate-100 flex items-center gap-3 transition-colors">
          <span class="p-2 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-xl transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l1.246-.356A.75.75 0 0017 14.27V10.74a.75.75 0 00-.52-.714L7.59 7.37a.75.75 0 00-.958.713v10.158c0 .85-.66 1.553-1.508 1.625l-.933.08a1.728 1.728 0 01-1.869-1.69c0-.915.68-1.683 1.592-1.748l1.107-.08a.75.75 0 00.697-.749V4.833a.75.75 0 01.963-.718l11.739 3.354a.75.75 0 01.54.718v2.261zm-7 5c0 .85-.66 1.553-1.508 1.625l-.933.08a1.728 1.728 0 01-1.869-1.69c0-.915.68-1.683 1.592-1.748l1.107-.08a.75.75 0 00.697-.749V10a.75.75 0 01.963-.718l11.739 3.354a.75.75 0 01.54.718v2.261z" />
            </svg>
