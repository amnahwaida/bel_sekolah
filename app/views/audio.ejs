<%- include('partials/header', { activePage: 'audio' }) %>

<!-- Header Page Info -->
<div class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6 px-2">
  <div>
    <h1 class="text-4xl font-black text-white tracking-tight flex items-center gap-4">
      <span class="w-2.5 h-10 bg-gradient-to-b from-primary-400 to-primary-700 rounded-full shadow-[0_0_15px_rgba(var(--primary-rgb),0.3)]"></span>
      Pustaka Audio
    </h1>
    <p class="text-slate-400 mt-2 font-medium italic">Kelola koleksi rekaman suara dan pengumuman sekolah.</p>
  </div>

  <div class="flex items-center gap-4">
    <form method="POST" action="/stop" class="contents" onsubmit="return handleStopSubmit(this)">
        <button type="submit" id="btnPanicStop" class="group relative px-8 py-4 bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white border border-red-500/20 rounded-2xl transition-all duration-300">
            <div class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 group-hover:scale-110 transition-transform">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 7.5A2.25 2.25 0 017.5 5.25h9a2.25 2.25 0 012.25 2.25v9a2.25 2.25 0 01-2.25 2.25h-9a2.25 2.25 0 01-2.25-2.25v-9z" />
                </svg>
                <span class="text-xs font-black uppercase tracking-[0.2em]" id="panicStopText">Panic Stop</span>
            </div>
        </button>
    </form>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
  <!-- UPLOAD SECTION -->
  <div class="lg:col-span-12 xl:col-span-4 space-y-8">
    <div class="glass-premium p-10 rounded-[3.5rem] border border-white/5 relative overflow-hidden group">
      <div class="absolute -right-20 -top-20 w-80 h-80 bg-primary-500 rounded-full opacity-5 blur-[100px] group-hover:opacity-10 transition-opacity"></div>
      
      <div class="relative z-10">
        <h3 class="text-2xl font-black text-white mb-6 flex items-center gap-4 tracking-tight">
          <div class="p-3 bg-primary-500/20 text-primary-500 rounded-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15a2.25 2.25 0 012.25 2.25v.75m-19.5 0A2.25 2.25 0 002.25 15v4.5a2.25 2.25 0 002.25 2.25h15a2.25 2.25 0 002.25-2.25V15a2.25 2.25 0 00-2.25-2.25m-19.5 0h19.5" />
            </svg>
          </div>
          New Upload
        </h3>
        <p class="text-slate-400 font-medium text-sm mb-10 italic pr-4 italic">Unggah file audio format .mp3 atau .wav untuk suara bel yang jernih.</p>
        
        <form method="POST" action="/upload" enctype="multipart/form-data" class="space-y-6">
          <div class="relative group/drag">
            <input type="file" name="audiofile" accept=".mp3,.wav" required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
            <div class="border-2 border-dashed border-white/10 rounded-[2.5rem] p-12 text-center transition-all group-hover/drag:border-primary-500/50 group-hover/drag:bg-primary-500/5">
              <div class="text-primary-500 mb-4 group-hover/drag:scale-110 transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-12 h-12 mx-auto">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
                </svg>
              </div>
              <p class="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em]">Drag & drop audio here</p>
              <p class="text-[9px] font-bold text-slate-600 mt-2">Max. 20MB per file</p>
            </div>
          </div>
          <button type="submit" id="btnUpload" class="w-full bg-primary-600 hover:bg-primary-500 text-white font-black py-6 rounded-3xl transition-all shadow-xl shadow-primary-500/20 uppercase tracking-[0.3em] text-xs active:scale-95" onclick="return handleUploadSubmit(this)">START UPLOAD</button>
        </form>
      </div>
    </div>

    <!-- QUICK CALL CONFIG (KID) -->
    <div class="glass-premium p-10 rounded-[3.5rem] border border-white/5 relative overflow-hidden group">
      <h3 class="text-xl font-black text-white mb-6 flex items-center gap-4 tracking-tight">
        <div class="p-3 bg-accent/20 text-accent rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.287a6 6 0 010 7.427M12 18.75V5.25" />
          </svg>
        </div>
        Quick Call Set
      </h3>
      <p class="text-slate-400 text-xs font-medium mb-8 leading-relaxed italic">Pilih file audio default untuk fitur "Panggilan Ketua Kelas" di Beranda Utama.</p>
      
      <form action="/config/quick-call" method="POST" class="space-y-6">
        <div class="max-h-[300px] overflow-y-auto pr-2 custom-scrollbar space-y-2">
          <% musicFiles.forEach(file => { %>
            <label class="block cursor-pointer">
              <input type="radio" name="filename" value="<%= file %>" class="peer hidden" <%= file === (locals.quickCallFile || '') ? 'checked' : '' %>>
              <div class="p-4 bg-black/40 rounded-2xl border-2 border-transparent peer-checked:border-accent peer-checked:bg-accent/10 transition-all text-[11px] font-black text-slate-300 peer-checked:text-white flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-slate-700 peer-checked:bg-accent"></div>
                <%= file %>
              </div>
            </label>
          <% }) %>
        </div>
        <button type="submit" class="w-full bg-accent/20 hover:bg-accent text-accent hover:text-white font-black py-5 rounded-2xl transition-all border border-accent/30 uppercase tracking-[0.2em] text-xs active:scale-95">UPDATE SHORTCUT</button>
      </form>
    </div>
  </div>

  <!-- REPOSITORY LIST -->
  <div class="lg:col-span-12 xl:col-span-8">
    <div class="glass-premium p-8 lg:p-12 rounded-[4rem] border border-white/5">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h3 class="text-2xl font-black text-white tracking-tight italic uppercase tracking-[0.2em] text-xs flex items-center gap-3">
            <span class="w-1.5 h-6 bg-primary-500 rounded-full"></span>
            Global Repository
          </h3>
          <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mt-2"><%= musicFiles.length %> items total in library</p>
        </div>
        <div class="hidden sm:block">
            <div class="px-5 py-2.5 bg-white/5 border border-white/5 rounded-full text-[10px] font-black text-slate-400 uppercase tracking-widest">
                Storage Path: /app/music
            </div>
        </div>
      </div>

      <div class="space-y-4 max-h-[1000px] overflow-y-auto pr-4 custom-scrollbar">
        <% musicFiles.forEach(f => { %>
          <div class="group bg-white/5 p-6 rounded-[2.5rem] border border-white/5 hover:bg-white/10 hover:border-emerald-500/30 transition-all duration-500 flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="flex items-center gap-6 min-w-0 flex-1 w-full md:w-auto">
              <div class="relative">
                <div class="w-16 h-16 bg-black/40 rounded-2xl flex items-center justify-center text-[10px] font-black uppercase text-primary-500 shadow-inner group-hover:scale-105 transition-transform">
                  MP3
                </div>
                <% if (f === quickCallFile) { %>
                    <div class="absolute -top-1 -right-1 w-6 h-6 bg-accent text-white flex items-center justify-center rounded-full border-4 border-[#0a0f1d]" title="Quick Call Shortcut">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3">
                        <path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.982 9.75h7.268a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.75a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 01.913-.143z" clip-rule="evenodd" />
                      </svg>
                    </div>
                <% } %>
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-base font-black text-white truncate pr-5 tracking-tight" title="<%= f %>"><%= f %></div>
                <div class="flex items-center gap-3 mt-1.5 opacity-40">
                    <span class="text-[9px] font-black uppercase tracking-widest transition-all group-hover:text-emerald-400">Audio Stream Ready</span>
                </div>
              </div>
            </div>

            <!-- Action Controls -->
            <div class="flex flex-wrap items-center gap-3 w-full md:w-auto justify-end">
              <div class="flex items-center gap-2 p-2 bg-black/40 rounded-2xl border border-white/5">
                <a href="/preview/<%= f %>" class="w-11 h-11 flex items-center justify-center rounded-xl text-primary-400 hover:bg-primary-500/20 hover:scale-110 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.287a6 6 0 010 7.427M12 18.75V5.25" />
                    </svg>
                </a>
                <form method="POST" action="/play" class="contents" onsubmit="return handlePlaySubmit(this)">
                  <input type="hidden" name="file" value="<%= f %>" />
                  <button type="submit" class="audio-play-btn w-11 h-11 flex items-center justify-center rounded-xl text-emerald-500 hover:bg-emerald-500/20 hover:scale-110 transition-all">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                        <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
                      </svg>
                  </button>
                </form>
                <form method="POST" action="/music/delete" class="contents" onsubmit="return handleDeleteSubmit(this)">
                  <input type="hidden" name="file" value="<%= f %>" />
                  <button type="submit" class="audio-delete-btn w-11 h-11 flex items-center justify-center rounded-xl text-red-500 hover:bg-red-500/20 hover:scale-110 transition-all">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                  </button>
                </form>
              </div>

              <form method="POST" action="/rename" class="contents">
                <input type="hidden" name="oldname" value="<%= f %>" />
                <div class="flex items-center gap-3 p-2 bg-black/40 rounded-2xl border border-white/5 min-w-[200px] group/rename">
                  <input type="text" name="newname" value="<%= f %>" class="bg-transparent text-[11px] font-black px-4 py-2.5 rounded-xl w-full outline-none text-slate-300 focus:text-white" maxlength="80" onfocus="this.select()" />
                  <button type="submit" class="w-11 h-11 flex items-center justify-center rounded-xl text-slate-500 hover:text-white hover:bg-white/5 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                    </svg>
                  </button>
                </div>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<script>
  // === ANTI-SPAM HANDLERS UNTUK AUDIO PAGE ===

  // Stop button anti-spam
  function handleStopSubmit(form) {
    const btn = form.querySelector('#btnPanicStop');
    const text = form.querySelector('#panicStopText');
    if (btn.disabled) return false;
    btn.disabled = true;
    btn.classList.add('opacity-50');
    btn.style.pointerEvents = 'none';
    if (text) text.innerText = '⏳ STOPPING...';
    setTimeout(() => {
      btn.disabled = false;
      btn.classList.remove('opacity-50');
      btn.style.pointerEvents = 'auto';
      if (text) text.innerText = 'Panic Stop';
    }, 3000);
    return true;
  }

  // Play button anti-spam (disable semua play button setelah salah satu diklik)
  function handlePlaySubmit(form) {
    const btn = form.querySelector('.audio-play-btn');
    if (btn.disabled) return false;
    // Disable semua tombol play
    document.querySelectorAll('.audio-play-btn').forEach(b => {
      b.disabled = true;
      b.classList.add('opacity-50');
      b.style.pointerEvents = 'none';
    });
    // Auto re-enable setelah 4 detik
    setTimeout(() => {
      document.querySelectorAll('.audio-play-btn').forEach(b => {
        b.disabled = false;
        b.classList.remove('opacity-50');
        b.style.pointerEvents = 'auto';
      });
    }, 4000);
    return true;
  }

  // Delete button anti-spam (confirm + disable)
  function handleDeleteSubmit(form) {
    const btn = form.querySelector('.audio-delete-btn');
    if (btn.disabled) return false;
    if (!confirm('Hapus file ini permanen?')) return false;
    btn.disabled = true;
    btn.classList.add('opacity-50');
    btn.style.pointerEvents = 'none';
    return true;
  }

  // Upload button anti-spam
  function handleUploadSubmit(btn) {
    if (btn.disabled) return false;
    btn.disabled = true;
    btn.classList.add('opacity-50');
    btn.innerText = '⏳ UPLOADING...';
    // Auto re-enable setelah 10 detik (jika upload lama)
    setTimeout(() => {
      btn.disabled = false;
      btn.classList.remove('opacity-50');
      btn.innerText = 'START UPLOAD';
    }, 10000);
    return true;
  }
</script>

<%- include('partials/footer') %>
