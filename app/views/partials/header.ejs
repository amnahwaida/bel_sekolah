<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="theme-color" content="<%= typeof branding !== 'undefined' && branding.themeColor ? branding.themeColor : '#1e3a8a' %>">
  <link rel="manifest" href="/manifest.json">
  <title><%= branding.pageTitle || '🔔 Bel Sekolah Premium' %></title>
  
  <script>
    // PWA Service Worker Registration
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('SW Registered', reg))
          .catch(err => console.log('SW Failed', err));
      });
    }

    // PWA Install Logic
    let deferredPrompt;
    window.addEventListener('beforeinstallprompt', (e) => {
      // Prevent Chrome 67 and earlier from automatically showing the prompt
      e.preventDefault();
      // Stash the event so it can be triggered later.
      deferredPrompt = e;
      // Show the install button in the sidebar
      const installContainer = document.getElementById('pwaInstallContainer');
      if (installContainer) installContainer.classList.remove('hidden');
    });

    window.addEventListener('DOMContentLoaded', () => {
        const btnInstall = document.getElementById('btnPWAInstall');
        if (btnInstall) {
            btnInstall.addEventListener('click', async () => {
                if (!deferredPrompt) return;
                // Show the prompt
                deferredPrompt.prompt();
                // Wait for the user to respond to the prompt
                const { outcome } = await deferredPrompt.userChoice;
                console.log(`User response to the install prompt: ${outcome}`);
                // We've used the prompt, and can't use it again, throw it away
                deferredPrompt = null;
                // Hide the install button
                const installContainer = document.getElementById('pwaInstallContainer');
                if (installContainer) installContainer.classList.add('hidden');
            });
        }
    });

    window.addEventListener('appinstalled', (event) => {
      console.log('App was installed.');
      const installContainer = document.getElementById('pwaInstallContainer');
      if (installContainer) installContainer.classList.add('hidden');
    });
  </script>
<% if (branding.faviconUrl) { %>
  <link rel="icon" href="<%= branding.faviconUrl %>">
<% } else { 
  const themeMap = {
    midnight: '#1e3a8a', emerald: '#065f46', amethyst: '#6b21a8', crimson: '#9f1239',
    amber: '#92400e', slated: '#334155', teal: '#115e59', indigo: '#3730a3',
    graphite: '#1e293b', aurora: '#0369a1'
  };
  const pCol = (themeMap[branding.theme] || '#1e3a8a').replace('#', '%23');
%>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><defs><linearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'><stop offset='0%25' stop-color='<%= pCol %>'/><stop offset='100%25' stop-color='<%= pCol %>ee'/></linearGradient></defs><rect width='32' height='32' rx='10' fill='url(%23g)'/><rect width='32' height='32' rx='10' fill='black' fill-opacity='0.1'/><svg x='6' y='6' width='20' height='20' viewBox='0 0 24 24'><path fill='white' d='M5.25 9a6.75 6.75 0 0113.5 0v.75c0 2.123.8 4.057 2.118 5.52a.75.75 0 01-.297 1.206c-1.544.57-3.16.99-4.831 1.243a3.75 3.75 0 11-7.48 0 24.585 24.585 0 01-4.831-1.244.75.75 0 01-.298-1.205A8.217 8.217 0 005.25 9.75V9zm4.502 8.9a2.25 2.25 0 104.496 0 25.057 25.057 0 01-4.496 0z' /></svg></svg>">
<% } %>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&display=swap" rel="stylesheet">
  
  <!-- Cropper.js for Branding Assets -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
  <script>
    // Force Dark Mode
    (function() {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
      
      // Initialize Sidebar State
      const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
      if (isCollapsed) {
        document.documentElement.classList.add('sidebar-is-collapsed');
      }
    })();
  </script>

  <script>
    // THEME PALETTES
    const themes = {
      midnight: { p: '#1e3a8a', a: '#312e81', g: 'rgba(30, 58, 138, 0.5)' },
      emerald:  { p: '#065f46', a: '#047857', g: 'rgba(6, 95, 70, 0.5)' },
      amethyst: { p: '#6b21a8', a: '#7e22ce', g: 'rgba(107, 33, 168, 0.5)' },
      crimson:  { p: '#9f1239', a: '#be123c', g: 'rgba(159, 18, 57, 0.5)' },
      amber:    { p: '#92400e', a: '#b45309', g: 'rgba(146, 64, 14, 0.5)' },
      slated:   { p: '#334155', a: '#475569', g: 'rgba(51, 65, 85, 0.5)' },
      teal:     { p: '#115e59', a: '#0f766e', g: 'rgba(17, 94, 89, 0.5)' },
      indigo:   { p: '#3730a3', a: '#4338ca', g: 'rgba(55, 48, 163, 0.5)' },
      graphite: { p: '#1e293b', a: '#334155', g: 'rgba(30, 41, 59, 0.5)' },
      aurora:   { p: '#0369a1', a: '#075985', g: 'rgba(3, 105, 161, 0.5)' }
    };

    const activeTheme = '<%= branding.theme || "midnight" %>';
    const config = themes[activeTheme] || themes.midnight;

    // Helper to get RGB from Hex
    function hexToRgb(hex) {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return `${r}, ${g}, ${b}`;
    }

    // Inject CSS Variables
    const style = document.createElement('style');
    style.innerHTML = `
      :root {
        --primary: ${config.p};
        --primary-rgb: ${hexToRgb(config.p)};
        --accent: ${config.a};
        --accent-rgb: ${hexToRgb(config.a)};
        --primary-glow: ${config.g};
      }
    `;
    document.head.appendChild(style);

    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['Outfit', 'sans-serif'] },
          colors: {
            primary: {
              50: 'color-mix(in srgb, var(--primary), white 90%)',
              100: 'color-mix(in srgb, var(--primary), white 80%)',
              200: 'color-mix(in srgb, var(--primary), white 60%)',
              500: 'var(--primary)',
              600: 'color-mix(in srgb, var(--primary), black 10%)',
              700: 'color-mix(in srgb, var(--primary), black 20%)',
              800: 'color-mix(in srgb, var(--primary), black 40%)',
              900: 'color-mix(in srgb, var(--primary), black 60%)',
            },
            accent: 'var(--accent)',
            success: '#10b981',
            warning: '#f59e0b',
            danger: '#ef4444',
          },
          animation: { 'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite' }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Outfit', sans-serif; transition: background-color 0.3s, color 0.3s; scroll-behavior: smooth; }
    
    .glass-premium {
      background: rgba(15, 23, 42, 0.5);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }

    .sidebar-glass {
      background: rgba(7, 10, 20, 0.9);
      backdrop-filter: blur(30px) saturate(200%);
      -webkit-backdrop-filter: blur(30px) saturate(200%);
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .main-content-transition {
      transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Sidebar Collapsed States */
    .sidebar-collapsed { width: 88px !important; }
    .sidebar-collapsed .nav-text, 
    .sidebar-collapsed .brand-text, 
    .sidebar-collapsed .user-info, 
    .sidebar-collapsed .logout-text,
    .sidebar-collapsed .section-label { 
      opacity: 0; 
      visibility: hidden; 
      display: none; 
    }
    .sidebar-collapsed .nav-item { justify-content: center; padding-left: 0; padding-right: 0; }
    .sidebar-collapsed .nav-icon,
    .sidebar-collapsed .logout-icon { margin-right: 0; width: 24px; height: 24px; }
    .sidebar-collapsed .brand-container { justify-content: center; padding-left: 0; padding-right: 0; }
    .sidebar-collapsed .bottom-section { padding-left: 1rem; padding-right: 1rem; }
    .sidebar-collapsed .logout-container { padding: 0; }
    .sidebar-collapsed .logout-container a { justify-content: center; padding-left: 0; padding-right: 0; }

    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    
    .gradient-text {
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .gradient-border {
      position: relative;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 1.5rem;
      z-index: 1;
    }
    .gradient-border::before {
      content: "";
      position: absolute;
      inset: -1px;
      padding: 1px;
      border-radius: 1.5rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      opacity: 0.2;
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      z-index: -1;
    }

    /* Mobile sidebar classes */
    .mobile-sidebar-open { transform: translateX(0) !important; width: 280px !important; }
    .mobile-overlay-open { opacity: 1 !important; pointer-events: auto !important; }
  </style>
</head>
