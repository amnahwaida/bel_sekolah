<%- include('partials/header', { activePage: 'schedules' }) %>

<!-- Header Page Info -->
<div class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6 px-2">
  <div>
    <h1 class="text-4xl font-black text-white tracking-tight flex items-center gap-4">
      <span class="w-2.5 h-10 bg-gradient-to-b from-primary-400 to-primary-700 rounded-full shadow-[0_0_15px_rgba(var(--primary-rgb),0.3)]"></span>
      Manajemen Jadwal
    </h1>
    <p class="text-slate-400 mt-2 font-medium italic">Atur jadwal bel reguler harian dan agenda khusus sekolah.</p>
  </div>

  <div class="flex items-center gap-4">
    <a href="/export/schedules.json" class="group relative px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl transition-all duration-300">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 text-primary-400 group-hover:-translate-y-0.5 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
        </svg>
        <span class="text-xs font-black uppercase tracking-[0.2em] text-white">Export JSON</span>
      </div>
    </a>

    <button onclick="toggleImportForm()" class="group relative px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl transition-all duration-300">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 text-primary-400 group-hover:translate-y-0.5 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        <span class="text-xs font-black uppercase tracking-[0.2em] text-white">Import JSON</span>
      </div>
    </button>
  </div>
</div>

<!-- Flash Messages for Schedules -->
<% if (locals.import === "success") { %>
  <div class="mb-8 animate-in">
    <div class="px-6 py-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl flex items-center gap-4">
      <div class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center text-white">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9.75-9.75" />
        </svg>
      </div>
      <span class="text-sm font-bold text-emerald-400 tracking-tight">Jadwal berhasil diimpor ke sistem.</span>
    </div>
  </div>
<% } %>

<!-- Import Form Section -->
<div id="importForm" class="hidden mb-12 animate-in slide-in-from-top-4 duration-500">
  <div class="glass-premium p-10 rounded-[3rem] border border-primary-500/20 shadow-[0_20px_60px_rgba(var(--primary-rgb),0.1)] relative overflow-hidden group">
    <div class="absolute -right-20 -top-20 w-80 h-80 bg-primary-500 rounded-full opacity-5 blur-[100px] group-hover:opacity-10 transition-opacity"></div>
    
    <div class="relative z-10">
      <h3 class="font-black text-white mb-6 flex items-center gap-3 italic uppercase tracking-[0.2em] text-xs">
        <span class="p-2 bg-primary-500/20 rounded-xl text-primary-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </span>
        Upload Configuration File
      </h3>
      <form method="POST" action="/import" enctype="multipart/form-data" class="flex flex-col md:flex-row gap-6">
        <div class="flex-1 group/input">
           <input type="file" name="importfile" accept=".json" required class="w-full p-4 bg-black/40 border border-white/5 rounded-2xl text-xs file:mr-4 file:py-2 file:px-6 file:rounded-full file:border-0 file:text-[10px] file:font-black file:uppercase file:bg-primary-500 file:text-white hover:file:bg-primary-600 transition-all font-bold text-slate-400" />
        </div>
        <div class="flex gap-4">
          <button type="submit" class="bg-gradient-to-r from-primary-500 to-accent text-white px-10 py-4 rounded-2xl font-black text-[11px] uppercase tracking-widest shadow-xl shadow-primary-500/20 active:scale-95 transition-all">PROCESS FILE</button>
          <button type="button" onclick="toggleImportForm()" class="px-8 py-4 bg-white/5 text-slate-400 hover:text-white rounded-2xl font-black text-[11px] uppercase tracking-widest transition-all">CANCEL</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
  <% const days = [
    { key: 'mon', name: 'Senin', color: 'from-primary-500 to-primary-700', glow: 'shadow-primary-500/25' },
    { key: 'tue', name: 'Selasa', color: 'from-primary-500 to-primary-700', glow: 'shadow-primary-500/25' },
    { key: 'wed', name: 'Rabu', color: 'from-primary-500 to-primary-700', glow: 'shadow-primary-500/25' },
    { key: 'thu', name: 'Kamis', color: 'from-primary-500 to-primary-700', glow: 'shadow-primary-500/25' },
    { key: 'fri', name: 'Jumat', color: 'from-primary-500 to-primary-700', glow: 'shadow-primary-500/25' },
    { key: 'sat', name: 'Sabtu', color: 'from-primary-500 to-primary-700', glow: 'shadow-primary-500/25' },
    { key: 'sun', name: 'Minggu', color: 'from-primary-500 to-primary-700', glow: 'shadow-primary-500/25' }
  ]; %>

  <% days.forEach(day => { %>
    <!-- DAY CARD -->
    <div class="glass-premium rounded-[3rem] p-8 flex flex-col hover:shadow-2xl transition-all duration-500 group/day border border-white/5 hover:border-white/20">
      <div class="flex items-center justify-between mb-8">
        <h3 class="text-sm font-black uppercase tracking-[0.3em] text-white italic">
          <%= day.name %>
        </h3>
        <div class="w-8 h-8 rounded-xl bg-gradient-to-br <%= day.color %> shadow-lg <%= day.glow %> flex items-center justify-center">
            <span class="text-[9px] font-black text-white italic uppercase"><%= day.key.charAt(0) %></span>
        </div>
      </div>
      
      <!-- List for each day -->
      <ul class="space-y-4 mb-8 flex-1 overflow-y-auto pr-1 custom-scrollbar max-h-[320px]">
        <% const list = schedules[day.key] || []; %>
        <% list.forEach((s, i) => { %>
          <li id="sched-view-<%= day.key %>-<%= i %>" class="group/item flex flex-col bg-white/5 p-4 rounded-2xl border border-white/5 hover:bg-white/10 hover:border-white/10 transition-all duration-300">
            <div class="flex justify-between items-center w-full mb-3">
                <span class="text-lg font-black text-white leading-none tracking-tighter"><%= s.time %></span>
                <div class="flex items-center gap-1">
                    <button type="button" onclick="toggleEditSchedule('<%= day.key %>', <%= i %>)" class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-white transition-all">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                      </svg>
                    </button>
                    <form method="POST" action="/schedule/remove" class="contents" onsubmit="return confirmDelete()">
                        <input type="hidden" name="day" value="<%= day.key %>" />
                        <input type="hidden" name="index" value="<%= i %>" />
                        <button type="submit" class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-danger duration-300">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                          </svg>
                        </button>
                    </form>
                </div>
            </div>
            <div class="bg-black/20 p-2.5 rounded-xl border border-white/5">
                <span class="text-[10px] font-black text-slate-400 truncate block tracking-widest uppercase italic" title="<%= s.sound %>"><%= s.sound %></span>
            </div>
          </li>

          <!-- Edit Mode Form -->
          <li id="sched-edit-<%= day.key %>-<%= i %>" class="hidden">
            <form method="POST" action="/schedule/edit" class="bg-gradient-to-br <%= day.color.replace('from-', 'from-').replace('to-', 'to-') %>/20 p-6 rounded-3xl border border-white/10 space-y-4">
              <input type="hidden" name="day" value="<%= day.key %>" />
              <input type="hidden" name="index" value="<%= i %>" />
              <div class="space-y-3">
                <input type="time" name="time" value="<%= s.time %>" onclick="this.showPicker()" class="w-full px-4 py-4 text-sm border-0 rounded-2xl outline-none bg-black/40 text-white font-black" required />
                <select name="sound" class="w-full px-4 py-4 text-[10px] border-0 rounded-2xl outline-none bg-black/40 text-white font-black truncate" required>
                  <% musicFiles.forEach(f => { %>
                    <option value="<%= f %>" <%= f === s.sound ? 'selected' : '' %>><%= f %></option>
                  <% }) %>
                </select>
              </div>
              <div class="flex gap-2">
                <button type="submit" class="flex-1 bg-white text-black py-4 rounded-xl text-[10px] font-black uppercase tracking-widest active:scale-95 transition-all">SAVE</button>
                <button type="button" onclick="toggleEditSchedule('<%= day.key %>', <%= i %>)" class="px-5 py-4 bg-black/20 text-white/50 rounded-xl text-[10px] font-black uppercase tracking-widest active:scale-95 transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
            </form>
          </li>
        <% }) %>
      </ul>

      <!-- Add Form for each day -->
      <form method="POST" action="/schedule/add" class="mt-auto pt-8 border-t border-white/5 flex flex-col gap-4">
        <input type="hidden" name="day" value="<%= day.key %>" />
        <div class="grid grid-cols-1 gap-4">
          <input type="time" name="time" onclick="this.showPicker()" class="w-full px-5 py-5 text-sm border-0 rounded-[1.5rem] outline-none bg-black/40 text-white font-black transition-all focus:ring-2 focus:ring-slate-500" required />
          <select name="sound" class="w-full px-5 py-5 text-[10px] border-0 rounded-[1.5rem] outline-none bg-black/40 text-white font-black truncate focus:ring-2 focus:ring-slate-500" required>
            <% musicFiles.forEach(f => { %>
              <option value="<%= f %>"><%= f %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="group py-5 bg-white/5 hover:bg-gradient-to-r <%= day.color %> text-slate-400 hover:text-white rounded-[1.5rem] text-[10px] font-black uppercase tracking-[0.3em] transition-all duration-300 flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          ADD NEW CALL
        </button>
      </form>
    </div>
  <% }) %>

  <!-- SPECIAL SCHEDULE CARD (Event Specific) -->
  <div class="md:col-span-2 lg:col-span-4 mt-8 glass-premium p-10 lg:p-14 rounded-[4rem] border border-accent/20 shadow-2xl relative overflow-hidden group/special">
    <div class="absolute -right-32 -bottom-32 w-96 h-96 bg-accent rounded-full opacity-[0.03] blur-[100px] group-hover/special:opacity-10 transition-opacity duration-1000"></div>
    
    <div class="flex flex-col xl:flex-row gap-16 relative z-10">
      <div class="xl:w-1/3">
        <h3 class="text-4xl font-black text-white flex items-center gap-5 tracking-tight leading-tight">
          <div class="w-16 h-16 rounded-[2rem] bg-primary-600 text-white flex items-center justify-center shadow-2xl shadow-primary-600/20">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008z" />
            </svg>
          </div>
          Event Specific
        </h3>
        <p class="text-slate-400 text-base mt-6 font-medium leading-relaxed italic pr-6 italic">Jadwal khusus berdasarkan tanggal untuk ujian, libur nasional, atau agenda insidental.</p>
        
        <form method="POST" action="/special/add" class="mt-12 space-y-6">
          <div class="grid grid-cols-2 gap-5">
            <div class="space-y-2">
              <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest px-1 italic">Event Date</label>
              <input type="date" name="date" onclick="this.showPicker()" class="w-full px-6 py-5 bg-black/40 border border-white/5 rounded-2xl outline-none focus:border-primary-500 text-white font-black text-xs transition-all" required />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest px-1 italic">Event Time</label>
              <input type="time" name="time" onclick="this.showPicker()" class="w-full px-6 py-5 bg-black/40 border border-white/5 rounded-2xl outline-none focus:border-primary-500 text-white font-black text-xs transition-all" required />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest px-1 italic">Call Audio File</label>
            <select name="sound" class="w-full px-6 py-5 bg-black/40 border border-white/5 rounded-2xl outline-none focus:border-primary-500 text-white font-black text-xs transition-all truncate" required>
              <% musicFiles.forEach(f => { %>
                <option value="<%= f %>"><%= f %></option>
              <% }) %>
            </select>
          </div>
          <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-black py-6 rounded-3xl transition-all shadow-2xl shadow-primary-600/20 active:scale-95 uppercase tracking-[0.3em] text-xs">Register Event Call</button>
        </form>
      </div>

      <div class="xl:flex-1 min-w-0">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-h-[600px] overflow-y-auto pr-4 custom-scrollbar">
          <% special.forEach((s, i) => { %>
            <div id="special-view-<%= i %>" class="group/spec relative glass-premium p-8 rounded-[3rem] border border-white/5 hover:border-accent/50 transition-all duration-500 hover:scale-[1.02]">
              <div class="flex items-center gap-6 mb-8">
                <div class="bg-gradient-to-br from-primary-500 to-accent w-16 h-16 rounded-2xl flex flex-col items-center justify-center shadow-xl shrink-0">
                  <span class="text-[9px] font-black text-white/50 uppercase tracking-widest leading-none mb-1.5"><%= s.date.split('-')[0] %></span>
                  <span class="text-xl font-black text-white leading-none"><%= s.date.split('-')[1] %>/<%= s.date.split('-')[2] %></span>
                </div>
                <div class="min-w-0">
                  <div class="text-2xl font-black text-white leading-none mb-2 tracking-tighter"><%= s.time %></div>
                  <div class="text-[9px] font-black text-slate-500 uppercase tracking-widest truncate max-w-[140px]" title="<%= s.sound %>"><%= s.sound %></div>
                </div>
              </div>
              <div class="flex items-center gap-3 pt-6 border-t border-white/5">
                <button type="button" onclick="toggleEditSpecial(<%= i %>)" class="flex-1 py-3 bg-white/5 hover:bg-white/10 text-white font-black text-[9px] uppercase tracking-widest rounded-xl transition-all">EDIT CALL</button>
                <form method="POST" action="/special/remove" class="contents" onsubmit="return confirmDelete()">
                  <input type="hidden" name="index" value="<%= i %>" />
                  <button type="submit" class="w-10 h-10 flex items-center justify-center bg-danger/10 text-danger rounded-xl hover:bg-danger hover:text-white transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </form>
              </div>
            </div>

            <!-- Special Edit Form -->
            <div id="special-edit-<%= i %>" class="hidden">
              <form method="POST" action="/special/edit" class="bg-primary-600/10 p-8 rounded-[3rem] border border-primary-500/30 space-y-6">
                <input type="hidden" name="index" value="<%= i %>" />
                <div class="grid grid-cols-2 gap-4">
                  <input type="date" name="date" value="<%= s.date %>" onclick="this.showPicker()" class="px-5 py-4 bg-black/40 border-0 rounded-2xl text-white font-black text-xs" required />
                  <input type="time" name="time" value="<%= s.time %>" onclick="this.showPicker()" class="px-5 py-4 bg-black/40 border-0 rounded-2xl text-white font-black text-xs" required />
                </div>
                <select name="sound" class="w-full px-5 py-4 bg-black/40 border-0 rounded-2xl text-white font-black text-xs truncate" required>
                  <% musicFiles.forEach(f => { %>
                    <option value="<%= f %>" <%= f === s.sound ? 'selected' : '' %>><%= f %></option>
                  <% }) %>
                </select>
                <div class="flex gap-3">
                  <button type="submit" class="flex-1 bg-white text-black font-black py-4 rounded-2xl text-[10px] uppercase tracking-widest active:scale-95 transition-all">UPDATE</button>
                  <button type="button" onclick="toggleEditSpecial(<%= i %>)" class="px-8 py-4 bg-black/20 text-white/50 font-black rounded-2xl text-[10px] uppercase tracking-widest transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
              </form>
            </div>
          <% }) %>
          
          <% if (special.length === 0) { %>
            <div class="sm:col-span-2 flex flex-col items-center justify-center py-32 opacity-20 italic">
                <p class="text-sm font-black uppercase tracking-[0.5em]">No Special Events Scheduled</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleEditSchedule(day, index) {
    document.getElementById(`sched-view-${day}-${index}`).classList.toggle('hidden');
    document.getElementById(`sched-edit-${day}-${index}`).classList.toggle('hidden');
  }
  function toggleEditSpecial(index) {
    document.getElementById(`special-view-${index}`).classList.toggle('hidden');
    document.getElementById(`special-edit-${index}`).classList.toggle('hidden');
  }
  function toggleImportForm() {
    document.getElementById('importForm').classList.toggle('hidden');
  }
  function confirmDelete() {
    return confirm('Are you sure you want to delete this schedule entry?');
  }
</script>

<%- include('partials/footer') %>
